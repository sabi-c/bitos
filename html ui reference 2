<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<title>BITOS · CHAT + TASKS + SETTINGS FLOWS</title>
<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;image-rendering:pixelated;transition:none!important;animation-timing-function:steps(1)!important}
body{background:#080808;color:#fff;font-family:'Press Start 2P',monospace;padding:40px 36px;line-height:1}
.pg-title{font-size:16px;letter-spacing:.04em;margin-bottom:6px}
.pg-sub{font-size:6px;color:#222;letter-spacing:.1em;margin-bottom:48px}
.sec-title{font-size:9px;letter-spacing:.08em;color:#333;margin-bottom:20px;padding-bottom:8px;border-bottom:1px solid #111}
.divider{border:none;border-top:2px solid #111;margin:52px 0}

/* ── FLOW DIAGRAM ── */
.flow-wrap{display:flex;flex-wrap:wrap;gap:48px;align-items:flex-start}
.flow-col{display:flex;flex-direction:column;gap:0}
.flow-hdr{background:#fff;color:#000;padding:6px 12px;font-size:7px;letter-spacing:.06em;border:2px solid #fff;border-bottom:3px solid #fff}
.flow-node{border:2px solid #333;padding:8px 12px;font-size:7px;letter-spacing:.04em;color:#555;border-top:none;display:flex;align-items:flex-start;gap:8px;flex-direction:column}
.flow-node.active{border-color:#fff;color:#fff}
.flow-node.sub{border-color:#1a1a1a;color:#222;font-size:6px}
.flow-node-lbl{font-size:6px;color:#1a1a1a;letter-spacing:.06em;margin-top:2px}
.flow-arrow{display:flex;align-items:center;gap:6px;padding:4px 0 4px 12px;font-size:5px;color:#1a1a1a;letter-spacing:.06em}
.flow-arrow-line{flex:1;border-top:1px solid #1a1a1a;min-width:20px}
.flow-connector{width:2px;background:#333;margin:0 auto;height:12px}
.flow-connector.dim{background:#111}
.flow-badge{font-size:5px;border:1px solid #333;padding:1px 5px;color:#333;letter-spacing:.06em;display:inline-block}
.flow-badge.short{border-color:#555;color:#555}
.flow-badge.long{border-color:#fff;color:#fff}
.flow-badge.dbl{border-color:#f44;color:#f44;font-size:4px}

/* ── DEVICE SHELL ── */
.devices-row{display:flex;flex-wrap:wrap;gap:36px;align-items:flex-start}
.device-wrap{display:flex;flex-direction:column;align-items:center;gap:10px}
.device-lbl{font-size:5px;color:#222;letter-spacing:.1em;text-align:center}
.device{background:#0d0d0d;border:3px solid #2a2a2a;padding:8px 8px 14px;display:flex;flex-direction:column;align-items:center;gap:8px}
.screen{width:240px;height:280px;background:#000;border:2px solid #555;position:relative;overflow:hidden;font-family:‘Press Start 2P’,monospace}
.home-btn{width:32px;height:5px;background:#1a1a1a;border:1px solid #222}

/* SHARED SCREEN PRIMITIVES */
.view{position:absolute;inset:0;display:none;flex-direction:column;background:#000}
.view.active{display:flex}
.sbar{height:18px;background:#fff;color:#000;display:flex;align-items:center;justify-content:space-between;padding:0 6px;font-size:6px;letter-spacing:.06em;flex-shrink:0;border-bottom:2px solid #fff}
.sbar.dark{background:#000;color:#fff;border-bottom-color:#333}
.kh{font-size:4px;color:#111;text-align:center;padding:2px 6px;letter-spacing:.06em;flex-shrink:0;border-top:1px solid #0a0a0a}
.inv-hdr{background:#fff;color:#000;padding:7px 8px;font-size:7px;letter-spacing:.06em;flex-shrink:0;border-bottom:2px solid #fff;display:flex;justify-content:space-between;align-items:center}
.scroll-body{flex:1;overflow:auto}
.scroll-body::-webkit-scrollbar{display:none}
.row{display:flex;align-items:center;gap:7px;padding:8px 8px;font-size:7px;letter-spacing:.04em;border-bottom:1px solid #0a0a0a;cursor:pointer;color:#555}
.row:last-child{border-bottom:none}
.row.focused{background:#fff;color:#000}
.row .arr{font-size:6px;flex-shrink:0;color:#333}
.row.focused .arr{color:#666}
.row .meta{margin-left:auto;font-size:5px;color:#333}
.row.focused .meta{color:#666}
.row .sub{font-size:5px;color:#2a2a2a;margin-top:2px;letter-spacing:.04em;display:block}
.row.focused .sub{color:#666}
.row-lbl{flex:1}
.bcur{display:inline-block;width:5px;height:9px;background:#fff;animation:bcu .8s steps(1) infinite;vertical-align:bottom}
@keyframes bcu{0%,100%{opacity:1}50%{opacity:0}}
.tdots{display:flex;gap:3px;padding:4px}
.td{width:4px;height:4px;background:#222}
.td:nth-child(1){animation:tda 1.2s steps(2) infinite 0.0s}
.td:nth-child(2){animation:tda 1.2s steps(2) infinite 0.3s}
.td:nth-child(3){animation:tda 1.2s steps(2) infinite 0.6s}
@keyframes tda{0%,100%{background:#222}50%{background:#fff}}
.pbar{height:5px;border:1px solid #fff;background:#000}
.pfill{height:100%;background:#fff}
.tog{width:22px;height:11px;border:2px solid #fff;position:relative;flex-shrink:0}
.tog-t{position:absolute;top:1px;width:7px;height:7px;background:#fff}
.tog.off{border-color:#333}
.tog.off .tog-t{background:#333;left:1px}
.tog.on .tog-t{right:1px}
.row.focused .tog{border-color:#000}
.row.focused .tog.on .tog-t{background:#000}
.row.focused .tog.off .tog-t{background:#666;background:#666}
.ldbar{height:5px;border:1px solid #fff;background:#000;overflow:hidden}
.ldfill{height:100%;width:20%;background:#fff;animation:lda 1.6s steps(8) infinite}
@keyframes lda{0%{transform:translateX(-100%)}100%{transform:translateX(600%)}}

/* ── CHAT SCREENS ── */
.msg-wrap{flex:1;padding:5px;display:flex;flex-direction:column;gap:4px;overflow:auto}
.msg-wrap::-webkit-scrollbar{display:none}
.msg{display:flex;gap:3px;align-items:flex-end}
.msg.me{flex-direction:row-reverse}
.av{width:14px;height:14px;border:2px solid #fff;font-size:4px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.bbl{border:2px solid #fff;padding:4px 5px;font-size:6px;line-height:1.6;max-width:160px}
.bbl.me{background:#fff;color:#000}
.stream-line{font-size:6px;color:#fff;letter-spacing:.03em;line-height:1.7;display:block}
.stream-line.dim{color:#333}
.stream-line.thinking{color:#444;font-size:5px}
.quick-row{display:flex;flex-wrap:wrap;gap:2px;padding:3px;border-top:2px solid #fff;flex-shrink:0}
.quick-btn{border:2px solid #2a2a2a;padding:3px 5px;font-size:5px;color:#333;cursor:pointer;letter-spacing:.04em}
.quick-btn.focused{border-color:#fff;color:#fff}
.chat-inp-bar{height:28px;border-top:2px solid #fff;display:flex;flex-shrink:0}
.chat-inp{flex:1;background:transparent;border:none;color:#fff;font-family:‘Press Start 2P’,monospace;font-size:5px;padding:4px 6px;outline:none}
.chat-inp::placeholder{color:#1a1a1a}
.chat-send{width:28px;border-left:2px solid #fff;background:#000;color:#fff;font-size:9px;display:flex;align-items:center;justify-content:center;cursor:pointer}
.chat-send:hover,.chat-send.on{background:#fff;color:#000}
.vring{width:70px;height:70px;border:3px solid #fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:26px}
.vring.rec{animation:vrp .6s steps(2) infinite}
@keyframes vrp{0%,100%{border-color:#fff}50%{border-color:#f44}}
.vbar{width:3px;background:#fff}
.vbar:nth-child(1){animation:vba .6s steps(4) infinite 0s}
.vbar:nth-child(2){animation:vba .6s steps(4) infinite .08s}
.vbar:nth-child(3){animation:vba .6s steps(4) infinite .16s}
.vbar:nth-child(4){animation:vba .6s steps(4) infinite .04s}
.vbar:nth-child(5){animation:vba .6s steps(4) infinite .12s}
.vbar:nth-child(6){animation:vba .6s steps(4) infinite .2s}
.vbar:nth-child(7){animation:vba .6s steps(4) infinite .06s}
@keyframes vba{0%{height:2px}25%{height:10px}50%{height:18px}75%{height:6px}}
.ctx-menu{border-top:3px solid #fff;flex-shrink:0}
.ctx-row{padding:8px 8px;font-size:7px;letter-spacing:.04em;color:#444;border-bottom:1px solid #0a0a0a;cursor:pointer;display:flex;align-items:center;gap:6px}
.ctx-row:last-child{border-bottom:none}
.ctx-row.focused{background:#fff;color:#000}
.ctx-row.danger{color:#f44}
.ctx-row.focused.danger{background:#f44;color:#000}
.think-hdr{padding:7px 8px;font-size:7px;display:flex;align-items:center;gap:6px;cursor:pointer;letter-spacing:.04em;border-bottom:1px solid #0a0a0a}
.think-hdr:hover,.think-hdr.open{background:#fff;color:#000}
.think-body{padding:8px;font-size:6px;color:#555;line-height:2;letter-spacing:.03em;border-bottom:1px solid #111}
.think-step{padding:2px 0;display:flex;gap:6px}
.think-num{color:#333;flex-shrink:0}
.think-step.done .think-num{color:#fff}

/* ── TASKS SCREENS ── */
.task-row{display:flex;align-items:center;gap:7px;padding:8px 8px;font-size:7px;letter-spacing:.04em;border-bottom:1px solid #0a0a0a;cursor:pointer;color:#aaa}
.task-row.focused{background:#fff;color:#000}
.task-cb{width:12px;height:12px;border:2px solid #444;display:flex;align-items:center;justify-content:center;font-size:7px;flex-shrink:0}
.task-cb.done{border-color:#fff;background:#fff;color:#000}
.task-row.focused .task-cb{border-color:#000}
.task-row.focused .task-cb.done{background:#000;color:#fff;border-color:#000}
.task-txt{flex:1}
.task-row.done-row .task-txt{text-decoration:line-through;color:#333}
.task-row.focused.done-row .task-txt{color:#888}
.pri{font-size:4px;border:1px solid #333;padding:1px 3px;color:#333;flex-shrink:0}
.pri.hi{border-color:#f44;color:#f44}
.task-row.focused .pri.hi{border-color:#000;color:#000}
.voice-add{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;padding:16px 8px}
.vn-btn{width:72px;height:72px;border:4px solid #fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:26px;cursor:pointer}
.vn-btn.recording{animation:vrp .6s steps(2) infinite}
.vn-btn.recording::after{content:’’;position:absolute;inset:-8px;border:2px solid #f44;border-radius:50%;animation:vrecring .6s steps(1) infinite}
@keyframes vrecring{0%,100%{opacity:1}50%{opacity:0}}
.vwave{height:28px;display:flex;align-items:center;gap:2px;justify-content:center}
.confirm-box{margin:8px;border:2px solid #fff;padding:12px 10px;display:flex;flex-direction:column;align-items:center;gap:8px;text-align:center}
.conf-btns{display:flex;gap:4px;width:100%;margin-top:4px}
.conf-btn{flex:1;border:2px solid #fff;padding:6px;font-size:6px;background:#000;color:#fff;font-family:‘Press Start 2P’,monospace;text-align:center;cursor:pointer}
.conf-btn.fill{background:#fff;color:#000}
.conf-btn.focused{background:#fff;color:#000}
.conf-btn.fill.focused{background:#000;color:#fff;border-style:dashed}

/* ── SETTINGS SCREENS ── */
.sett-section{padding:4px 8px;font-size:5px;color:#1a1a1a;letter-spacing:.12em;background:#050505;border-bottom:1px solid #080808;border-top:1px solid #080808}
.model-row{display:flex;align-items:center;gap:6px;padding:8px;border-bottom:1px solid #0a0a0a;cursor:pointer;font-size:7px;letter-spacing:.04em}
.model-row.focused{background:#fff;color:#000}
.model-row .model-badge{font-size:5px;border:1px solid #555;padding:1px 4px;color:#555;flex-shrink:0}
.model-row.focused .model-badge{border-color:#000;color:#000}
.model-row.active-model{color:#fff}
.model-row.focused.active-model{color:#000}
.about-row{padding:7px 8px;border-bottom:1px solid #0a0a0a;display:flex;justify-content:space-between;font-size:6px;letter-spacing:.04em}
.about-lbl{color:#444}
.about-val{color:#aaa}

/* ── CONTROLS ── */
.btn-row{display:flex;gap:6px;flex-wrap:wrap;justify-content:center}
.ctrl-btn{border:2px solid #333;padding:5px 10px;font-size:5px;color:#555;cursor:pointer;letter-spacing:.06em;font-family:‘Press Start 2P’,monospace;background:#000}
.ctrl-btn:hover{border-color:#fff;color:#fff}
.ctrl-btn.danger:hover{border-color:#f44;color:#f44}
.state-display{font-size:5px;color:#1a1a1a;text-align:center;letter-spacing:.06em;margin-top:4px}
</style>

</head>
