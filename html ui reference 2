<script>
/* ═══ SHARED UTILS ═══ */
function showView(scrId, viewId) {
  document.querySelectorAll('#'+scrId+' .view').forEach(v => v.classList.remove('active'));
  document.getElementById(viewId).classList.add('active');
}
function focusList(listId, idx) {
  const rows = document.querySelectorAll('#'+listId+' [data-i]');
  rows.forEach((r, i) => r.classList.toggle('focused', i === idx));
  if (rows[idx]) rows[idx].scrollIntoView({block:'nearest'});
  return rows.length;
}
function flash(el, ms=120) {
  if (!el) return;
  const orig = el.style.background;
  el.style.background = '#fff';
  el.style.color = '#000';
  setTimeout(() => { el.style.background = orig; el.style.color = ''; }, ms);
}
function tick() {
  const n = new Date();
  const t = String(n.getHours()).padStart(2,'0')+':'+String(n.getMinutes()).padStart(2,'0');
  document.querySelectorAll('[id$="time"]').forEach(e => { if(e.id.includes('time')) e.textContent = t; });
  if (document.getElementById('Atime')) document.getElementById('Atime').textContent = t;
}
tick(); setInterval(tick, 1000);
function setState(id, txt) { const el = document.getElementById(id); if(el) el.textContent = txt; }

/* ═══════════════════════════════════
   DEVICE A · CHAT
═══════════════════════════════════ */
let A_screen = 'chatpanel';
let A_panelIdx = 0;
let A_ctxIdx = 0;
let A_histIdx = 0;
let A_quickIdx = 0;
let A_vtSec = 0;
let A_vtInt = null;

function A_goTo(s) {
  A_screen = s;
  showView('scrA', 'A_'+s);
  setState('A_state', s.replace(/_/g,' '));
}

// Ring animation for thinking
let A_rs = 0;
function A_drawRing() {
  const c = document.getElementById('A_ring');
  if (!c) return;
  c.width = 72; c.height = 72;
  const ctx = c.getContext('2d');
  ctx.imageSmoothingEnabled = false;
  ctx.clearRect(0,0,72,72);
  ctx.strokeStyle='#1a1a1a'; ctx.lineWidth=5;
  ctx.beginPath(); ctx.arc(36,36,28,0,Math.PI*2); ctx.stroke();
  ctx.strokeStyle='#fff'; ctx.lineWidth=5;
  ctx.beginPath(); ctx.arc(36,36,28,-Math.PI/2,-Math.PI/2+Math.PI*2*(A_rs/16)); ctx.stroke();
}
let A_ringInt = null;
function A_startThink() {
  A_rs = 0;
  let dots = 0; let tok = 0;
  A_ringInt = setInterval(() => {
    A_rs = (A_rs+1)%17; A_drawRing();
    dots = (dots+1)%3;
    tok += 58;
    const de = document.getElementById('A_dots');
    const te = document.getElementById('A_tok');
    if(de) de.textContent = ['.','..','.'][dots];
    if(te) te.textContent = tok;
    if(A_rs === 0) {
      clearInterval(A_ringInt);
      A_goTo('chat');
    }
  }, 200);
}

function A_short() {
  if (A_screen === 'chatpanel') {
    A_panelIdx = (A_panelIdx + 1) % 3;
    focusList('A_chatpanel', A_panelIdx);
  } else if (A_screen === 'chat') {
    A_quickIdx = (A_quickIdx + 1) % 4;
    focusList('A_quick', A_quickIdx);
  } else if (A_screen === 'ctx') {
    A_ctxIdx = (A_ctxIdx + 1) % 4;
    focusList('A_ctxmenu', A_ctxIdx);
  } else if (A_screen === 'history') {
    A_histIdx = (A_histIdx + 1) % 6;
    focusList('A_histlist', A_histIdx);
  } else if (A_screen === 'voice') {
    A_goTo('chat'); // send on short when in voice
  }
}

function A_long() {
  if (A_screen === 'chatpanel') {
    if (A_panelIdx === 0) { A_goTo('thinking'); A_startThink(); }
    else if (A_panelIdx === 1) { A_histIdx = 0; focusList('A_histlist', 0); A_goTo('history'); }
    else if (A_panelIdx === 2) { A_histIdx = 0; focusList('A_histlist', 0); A_goTo('history'); }
  } else if (A_screen === 'chat') {
    A_goTo('voice');
    A_vtSec = 0;
    A_vtInt = setInterval(() => {
      A_vtSec++;
      const el = document.getElementById('A_vtimer');
      if(el) el.textContent = '00:'+String(A_vtSec).padStart(2,'0');
    }, 1000);
  } else if (A_screen === 'voice') {
    clearInterval(A_vtInt);
    A_vtSec = 0;
    A_goTo('thinking');
    A_startThink();
  } else if (A_screen === 'ctx') {
    const rows = document.querySelectorAll('#A_ctxmenu [data-i]');
    const el = rows[A_ctxIdx];
    if(el) flash(el);
    setTimeout(() => A_goTo('chat'), 200);
  } else if (A_screen === 'history') {
    const rows = document.querySelectorAll('#A_histlist [data-i]');
    if(rows[A_histIdx]) flash(rows[A_histIdx]);
    setTimeout(() => { A_quickIdx=0; focusList('A_quick',0); A_goTo('chat'); }, 200);
  }
}

function A_back() {
  if (A_screen === 'chat') { A_panelIdx=0; focusList('A_chatpanel',0); A_goTo('chatpanel'); }
  else if (A_screen === 'voice') { clearInterval(A_vtInt); A_goTo('chat'); }
  else if (A_screen === 'thinking') { clearInterval(A_ringInt); A_goTo('chat'); }
  else if (A_screen === 'ctx') A_goTo('chat');
  else if (A_screen === 'history') { A_panelIdx=0; focusList('A_chatpanel',0); A_goTo('chatpanel'); }
}

/* ═══════════════════════════════════
   DEVICE B · TASKS
═══════════════════════════════════ */
let B_screen = 'taskpanel';
let B_panelIdx = 0;
let B_taskIdx = 0;
let B_projIdx = 0;
let B_confIdx = 0;
let B_vrec = false;
let B_vtSec = 0;
let B_vtInt = null;

function B_goTo(s) {
  B_screen = s;
  showView('scrB', 'B_'+s);
  setState('B_state', s.replace(/_/g,' '));
}

function B_short() {
  if (B_screen === 'taskpanel') {
    B_panelIdx = (B_panelIdx+1) % 3;
    focusList('B_panel_list', B_panelIdx);
  } else if (B_screen === 'tasklist') {
    B_taskIdx = (B_taskIdx+1) % 7;
    focusList('B_tlist', B_taskIdx);
  } else if (B_screen === 'projects') {
    B_projIdx = (B_projIdx+1) % 5;
    focusList('B_projlist', B_projIdx);
  } else if (B_screen === 'confirm') {
    B_confIdx = (B_confIdx+1) % 2;
    focusList('B_confbtns', B_confIdx);
  }
}

function B_long() {
  if (B_screen === 'taskpanel') {
    if (B_panelIdx===0) { B_taskIdx=0; focusList('B_tlist',0); B_goTo('tasklist'); }
    else if (B_panelIdx===1) { B_projIdx=0; focusList('B_projlist',0); B_goTo('projects'); }
    else if (B_panelIdx===2) B_goTo('voiceadd');
  } else if (B_screen === 'tasklist') {
    const rows = document.querySelectorAll('#B_tlist [data-i]');
    const row = rows[B_taskIdx];
    if (row) {
      const cb = row.querySelector('.task-cb');
      if (cb) {
        const done = cb.classList.toggle('done');
        cb.textContent = done ? '✓' : '□';
        row.classList.toggle('done-row', done);
        flash(row, 80);
      }
    }
  } else if (B_screen === 'voiceadd') {
    if (!B_vrec) {
      B_vrec = true;
      B_vtSec = 0;
      const stEl = document.getElementById('B_vstatus');
      const btn = document.getElementById('B_vnbtn');
      if(stEl) stEl.textContent = 'RECORDING...';
      if(btn) btn.classList.add('recording');
      B_vtInt = setInterval(() => {
        B_vtSec++;
        const el = document.getElementById('B_vtimer');
        if(el) el.textContent = '00:'+String(B_vtSec).padStart(2,'0');
        if (B_vtSec >= 15) { B_stopRec(); }
      }, 1000);
    } else {
      B_stopRec();
      B_confIdx = 0;
      focusList('B_confbtns', 0);
      B_goTo('confirm');
    }
  } else if (B_screen === 'confirm') {
    const rows = document.querySelectorAll('#B_confbtns [data-i]');
    if (B_confIdx === 1) { // SAVE
      flash(rows[1]);
      setTimeout(() => { B_taskIdx=0; focusList('B_tlist',0); B_goTo('tasklist'); }, 200);
    } else { // CANCEL
      B_goTo('tasklist');
    }
  } else if (B_screen === 'projects') {
    const rows = document.querySelectorAll('#B_projlist [data-i]');
    if(rows[B_projIdx]) flash(rows[B_projIdx]);
    setTimeout(() => B_goTo('tasklist'), 200);
  }
}

function B_stopRec() {
  clearInterval(B_vtInt);
  B_vrec = false;
  B_vtSec = 0;
  const stEl = document.getElementById('B_vstatus');
  const btn = document.getElementById('B_vnbtn');
  const timer = document.getElementById('B_vtimer');
  if(stEl) stEl.textContent = 'LONG PRESS TO START';
  if(btn) btn.classList.remove('recording');
  if(timer) timer.textContent = '00:00';
}

function B_back() {
  if (B_screen === 'tasklist') { B_panelIdx=0; focusList('B_panel_list',0); B_goTo('taskpanel'); }
  else if (B_screen === 'voiceadd') { B_stopRec(); B_goTo('taskpanel'); }
  else if (B_screen === 'confirm') { B_stopRec(); B_goTo('voiceadd'); }
  else if (B_screen === 'projects') { B_panelIdx=0; focusList('B_panel_list',0); B_goTo('taskpanel'); }
}

/* ═══════════════════════════════════
   DEVICE C · SETTINGS
═══════════════════════════════════ */
let C_screen = 'settmain';
let C_settIdx = 0;
let C_modelIdx = 0;
let C_agentIdx = 0;
let C_wifiIdx = 0;
let C_btIdx = 0;

const C_SETT_TOTAL = 8;
const C_ACTIONS = ['model','agent','toggle','toggle','wifi','bt','storage','about'];

function C_goTo(s) {
  C_screen = s;
  showView('scrC', 'C_'+s);
  setState('C_state', s.replace(/_/g,' '));
}

function C_short() {
  if (C_screen === 'settmain') {
    C_settIdx = (C_settIdx+1) % C_SETT_TOTAL;
    focusList('C_settlist', C_settIdx);
  } else if (C_screen === 'model') {
    C_modelIdx = (C_modelIdx+1) % 4;
    focusList('C_modellist', C_modelIdx);
  } else if (C_screen === 'agent') {
    C_agentIdx = (C_agentIdx+1) % 6;
    focusList('C_agentlist', C_agentIdx);
  } else if (C_screen === 'wifi') {
    C_wifiIdx = (C_wifiIdx+1) % 4;
    focusList('C_wifilist', C_wifiIdx);
  } else if (C_screen === 'bt') {
    C_btIdx = (C_btIdx+1) % 4;
    focusList('C_btlist', C_btIdx);
  }
}

function C_long() {
  if (C_screen === 'settmain') {
    const action = C_ACTIONS[C_settIdx];
    if (action === 'toggle') {
      // Find the toggle in focused row
      const rows = document.querySelectorAll('#C_settlist [data-i]');
      const tog = rows[C_settIdx]?.querySelector('.tog');
      if (tog) {
        tog.classList.toggle('on');
        tog.classList.toggle('off');
        const t = tog.querySelector('.tog-t');
        if(t) {
          if(tog.classList.contains('on')) { t.style.right='1px'; t.style.left=''; }
          else { t.style.left='1px'; t.style.right=''; }
        }
      }
    } else if (action === 'model') { C_modelIdx=0; focusList('C_modellist',0); C_goTo('model'); }
    else if (action === 'agent') { C_agentIdx=0; focusList('C_agentlist',0); C_goTo('agent'); }
    else if (action === 'wifi') { C_wifiIdx=0; focusList('C_wifilist',0); C_goTo('wifi'); }
    else if (action === 'bt') { C_btIdx=0; focusList('C_btlist',0); C_goTo('bt'); }
    else if (action === 'storage') C_goTo('storage');
    else if (action === 'about') C_goTo('about');
  } else if (C_screen === 'model') {
    // Update all rows: clear active, set new
    const rows = document.querySelectorAll('#C_modellist [data-i]');
    rows.forEach((r,i) => {
      r.classList.toggle('active-model', i===C_modelIdx);
      const badge = r.querySelector('.model-badge');
      if(badge) badge.textContent = i===C_modelIdx ? 'ACTIVE ✓' : (['PRO','FAST','SOON'][i-1]||'');
    });
    flash(rows[C_modelIdx]);
    setTimeout(() => { C_settIdx=0; focusList('C_settlist',0); C_goTo('settmain'); }, 300);
  } else if (C_screen === 'agent') {
    const rows = document.querySelectorAll('#C_agentlist [data-i]');
    rows.forEach((r,i) => {
      r.classList.toggle('active-model', i===C_agentIdx);
      const badge = r.querySelector('.model-badge');
      if(badge) badge.textContent = i===C_agentIdx ? 'ACTIVE' : '';
    });
    flash(rows[C_agentIdx]);
    setTimeout(() => { C_settIdx=0; focusList('C_settlist',0); C_goTo('settmain'); }, 300);
  } else if (C_screen === 'wifi') {
    const rows = document.querySelectorAll('#C_wifilist [data-i]');
    if(rows[C_wifiIdx]) flash(rows[C_wifiIdx]);
    setTimeout(() => C_goTo('settmain'), 200);
  } else if (C_screen === 'bt') {
    const rows = document.querySelectorAll('#C_btlist [data-i]');
    if(rows[C_btIdx]) flash(rows[C_btIdx]);
    setTimeout(() => C_goTo('settmain'), 200);
  }
}

function C_back() {
  if (['model','agent','wifi','bt','storage','about'].includes(C_screen)) {
    C_settIdx = 0; focusList('C_settlist',0); C_goTo('settmain');
  }
}

/* ═══ KEYBOARD ═══ */
document.addEventListener('keydown', e => {
  if (['INPUT','TEXTAREA'].includes(document.activeElement.tagName)) return;
  if (e.key === ' ') { e.preventDefault(); A_short(); B_short(); C_short(); }
  if (e.key === 'Enter') { e.preventDefault(); A_long(); B_long(); C_long(); }
  if (e.key === 'Backspace' || e.key === 'Escape') { e.preventDefault(); A_back(); B_back(); C_back(); }
});
</script>

