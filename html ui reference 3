<script>
/* ════ UTILS ════ */
function sv(scrId,viewId){document.querySelectorAll('#'+scrId+' .view').forEach(v=>v.classList.remove('active'));document.getElementById(viewId)?.classList.add('active');}
function fl(listId,idx){const rows=document.querySelectorAll('#'+listId+' [data-i]');rows.forEach((r,i)=>r.classList.toggle('focused',i===idx));if(rows[idx])rows[idx].scrollIntoView({block:'nearest'});return rows.length;}
function flash(el,ms=120){if(!el)return;const prevBg=el.style.background,prevC=el.style.color;el.style.background='#fff';el.style.color='#000';setTimeout(()=>{el.style.background=prevBg;el.style.color=prevC;},ms);}
function st(id,txt){const e=document.getElementById(id);if(e)e.textContent=txt;}

/* ════ NOTIFICATION SYSTEM ════ */
const toastQueues={};
function fireNotif(dev,type,icon,app,msg,time){
  const toast=document.getElementById(dev+'_toast');
  const icons={mail:'#D85A30',sms:'#1D9E75',task:'#BA7517',claude:'#7F77DD'};
  if(!toast)return;
  document.getElementById(dev+'_ti').textContent=icon;
  document.getElementById(dev+'_ti').style.color=icons[type]||'#fff';
  document.getElementById(dev+'_ta').textContent=app;
  document.getElementById(dev+'_tm').textContent=msg;
  document.getElementById(dev+'_tt').textContent=time;
  toast.classList.add('visible');
  // progress bar animation
  const prog=document.getElementById(dev+'_tp');
  if(prog){prog.style.width='0%';let pct=0;const pi=setInterval(()=>{pct+=2;prog.style.width=pct+'%';if(pct>=100){clearInterval(pi);toast.classList.remove('visible');prog.style.width='0%';}},100);}
}

/* ════ CLOCK ════ */
function tick(){const n=new Date();const t=String(n.getHours()).padStart(2,'0')+':'+String(n.getMinutes()).padStart(2,'0');['At','Bt','Ct','Dt'].forEach(id=>{const e=document.getElementById(id);if(e)e.textContent=t;});}
tick();setInterval(tick,1000);

/* ════ WORLD CLOCKS ════ */
const CZ=[{id:'LA',tz:'America/Los_Angeles'},{id:'NY',tz:'America/New_York'},{id:'LN',tz:'Europe/London'},{id:'TK',tz:'Asia/Tokyo'}];
const DAYS=['SUN','MON','TUE','WED','THU','FRI','SAT'],MONS=['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
function drawClk(id,h,m,s){const c=document.getElementById('clk'+id);if(!c)return;c.width=52;c.height=52;const ctx=c.getContext('2d');ctx.imageSmoothingEnabled=false;ctx.clearRect(0,0,52,52);ctx.strokeStyle='#444';ctx.lineWidth=1.5;ctx.beginPath();ctx.arc(26,26,23,0,Math.PI*2);ctx.stroke();for(let i=0;i<12;i++){const a=i*Math.PI/6;ctx.beginPath();ctx.moveTo(26+20*Math.sin(a),26-20*Math.cos(a));ctx.lineTo(26+23*Math.sin(a),26-23*Math.cos(a));ctx.strokeStyle='#333';ctx.lineWidth=1;ctx.stroke();}const ha=(h%12+m/60)*Math.PI/6;ctx.beginPath();ctx.moveTo(26,26);ctx.lineTo(26+12*Math.sin(ha),26-12*Math.cos(ha));ctx.strokeStyle='#fff';ctx.lineWidth=2;ctx.stroke();const ma=(m+s/60)*Math.PI/30;ctx.beginPath();ctx.moveTo(26,26);ctx.lineTo(26+18*Math.sin(ma),26-18*Math.cos(ma));ctx.strokeStyle='#fff';ctx.lineWidth=1.5;ctx.stroke();const sa=s*Math.PI/30;ctx.beginPath();ctx.moveTo(26,26);ctx.lineTo(26+21*Math.sin(sa),26-21*Math.cos(sa));ctx.strokeStyle='#aaa';ctx.lineWidth=1;ctx.stroke();}
function updateClocks(){CZ.forEach(z=>{const n=new Date(new Date().toLocaleString('en-US',{timeZone:z.tz}));const h=n.getHours(),m=n.getMinutes(),s=n.getSeconds();drawClk(z.id,h,m,s);const h12=h%12||12;st('clk'+z.id+'t',String(h12).padStart(2,'0')+':'+String(m).padStart(2,'0'));st('clk'+z.id+'ap',h>=12?'PM':'AM');st('clk'+z.id+'d',DAYS[n.getDay()]+' '+n.getDate()+' '+MONS[n.getMonth()]);})}
updateClocks();setInterval(updateClocks,1000);

/* ════ POMODORO ════ */
let pomoRun=false,pomoSec=25*60,pomoTotal=25*60,pomoBreak=false,pomoRound=1,pomoInt=null;
function pomoFmt(s){return String(Math.floor(s/60)).padStart(2,'0')+':'+String(s%60).padStart(2,'0');}
function pomoRender(){
  st('A_pomotime',pomoFmt(pomoSec));
  const pct=Math.round((1-pomoSec/pomoTotal)*100);
  const pf=document.getElementById('A_pomoprog');if(pf)pf.style.width=pct+'%';
  st('A_pomophase',pomoBreak?'SHORT BREAK':'WORK SESSION');
  st('A_pomosess',(pomoBreak?'BREAK':'WORK')+' · '+pomoRound+'/4');
  const eta=new Date(Date.now()+pomoSec*1000);
  const etas=String(eta.getHours()%12||12).padStart(2,'0')+':'+String(eta.getMinutes()).padStart(2,'0');
  st('A_pomoeta',pct+'% · DONE '+etas);
  const pw=document.getElementById('A_pomo_dots');
  if(pw){pw.querySelectorAll('.pomo-dot').forEach((d,i)=>d.classList.toggle('done',i<pomoRound));}
  const view=document.getElementById('A_pomo');
  if(view)view.classList.toggle('break-mode',pomoBreak);
}
function A_pomoToggle(){pomoRun=!pomoRun;st('A_pomobtn',pomoRun?'PAUSE':'RESUME');if(pomoRun&&!pomoInt){pomoInt=setInterval(()=>{if(!pomoRun)return;pomoSec--;if(pomoSec<=0){pomoBreak=!pomoBreak;pomoTotal=pomoBreak?5*60:25*60;pomoSec=pomoTotal;if(!pomoBreak)pomoRound=Math.min(4,pomoRound+1);}pomoRender();},1000);};}
function A_pomoSkip(){pomoBreak=!pomoBreak;pomoTotal=pomoBreak?5*60:25*60;pomoSec=pomoTotal;if(!pomoBreak)pomoRound=Math.min(4,pomoRound+1);pomoRender();}
function A_pomoReset(){clearInterval(pomoInt);pomoInt=null;pomoRun=false;pomoSec=25*60;pomoTotal=25*60;pomoBreak=false;pomoRound=1;st('A_pomobtn','START');pomoRender();}
pomoRender();

/* ════ STOPWATCH ════ */
let swRun=false,swMs=0,swInt2=null,swLaps=[],swBest=-1,swWorst=-1,swLast=0;
function swFmt(){const t=Math.floor(swMs/10);return String(Math.floor(t/6000)).padStart(2,'0')+':'+String(Math.floor((t%6000)/100)).padStart(2,'0');}
function swRender(){st('A_swt',swFmt());st('A_swms','.'+String(swMs%100).padStart(2,'0')+'0');}
function swToggle(){swRun=!swRun;const b=document.getElementById('A_swbtn');if(b)b.textContent=swRun?'STOP':'START';if(b)b.classList.toggle('active',swRun);if(swRun)swInt2=setInterval(()=>{swMs++;swRender();},10);else clearInterval(swInt2);}
function swLap(){if(!swRun)return;const l=swMs-swLast;swLast=swMs;swLaps.unshift(l);if(swBest<0||l<swBest)swBest=l;if(swWorst<0||l>swWorst)swWorst=l;const c=document.getElementById('A_laps');c.innerHTML=swLaps.map((lap,i)=>`<div class="sw-lap${lap===swBest?' best':lap===swWorst?' worst':''}"><span class="sw-lap-n">LAP ${swLaps.length-i}</span><span>${String(Math.floor(lap/600000)).padStart(2,'0')}:${String(Math.floor((lap%600000)/10000)).padStart(2,'0')}.${String(Math.floor((lap%10000)/100)).padStart(2,'0')}</span></div>`).join('');}
function swReset(){clearInterval(swInt2);swRun=false;swMs=0;swLaps=[];swBest=-1;swWorst=-1;swLast=0;const b=document.getElementById('A_swbtn');if(b){b.textContent='START';b.classList.remove('active');}swRender();const c=document.getElementById('A_laps');c.innerHTML='<div style="font-size:5px;color:#1a1a1a;text-align:center;padding:10px;letter-spacing:.06em">PRESS LAP TO RECORD</div>';}

/* ════ DEVICE A: FOCUS ════ */
let As='panel',Ai=0;
function A_short(){
  if(As==='panel'){Ai=(Ai+1)%3;fl('A_plist',Ai);}
  else if(As==='pomo'){A_pomoToggle();}
  else if(As==='sw'){swToggle();}
}
function A_long(){
  if(As==='panel'){
    if(Ai===0){As='pomo';sv('scrA','A_pomo');st('A_st','pomodoro');}
    else if(Ai===1){As='clocks';sv('scrA','A_clocks');st('A_st','world clocks');}
    else{As='sw';sv('scrA','A_sw');st('A_st','stopwatch');}
  } else if(As==='pomo'){A_pomoSkip();}
  else if(As==='sw'){swLap();}
}
function A_back(){if(As!=='panel'){As='panel';sv('scrA','A_panel');Ai=0;fl('A_plist',0);st('A_st','focus panel');}}

/* ════ DEVICE B: MAIL ════ */
let Bs='panel',Bi=0,Bai=0,Bii=0;
function B_short(){
  if(Bs==='panel'){Bi=(Bi+1)%6;fl('B_plist',Bi);}
  else if(Bs==='detail'){Bai=(Bai+1)%4;fl('B_acts',Bai);}
  else if(Bs==='inbox'){Bii=(Bii+1)%5;fl('B_ilist',Bii);}
}
function B_long(){
  if(Bs==='panel'){
    if(Bi<=3){Bs='detail';sv('scrB','B_detail');Bai=0;fl('B_acts',0);st('B_st','email detail');}
    else if(Bi===4){Bs='inbox';sv('scrB','B_inbox');Bii=0;fl('B_ilist',0);st('B_st','full inbox');}
    else{Bs='compose';sv('scrB','B_compose');st('B_st','compose');}
  } else if(Bs==='detail'){
    const rows=document.querySelectorAll('#B_acts [data-i]');flash(rows[Bai]);
    setTimeout(()=>{Bs='panel';sv('scrB','B_panel');Bi=0;fl('B_plist',0);st('B_st','mail panel');},200);
  } else if(Bs==='inbox'){
    const rows=document.querySelectorAll('#B_ilist [data-i]');flash(rows[Bii]);
    setTimeout(()=>{Bs='detail';sv('scrB','B_detail');st('B_st','email detail');},200);
  }
}
function B_back(){
  if(Bs==='detail'||Bs==='inbox'||Bs==='compose'){Bs='panel';sv('scrB','B_panel');Bi=0;fl('B_plist',0);st('B_st','mail panel');}
}

/* ════ DEVICE C: MESSAGES ════ */
let Cs='panel',Ci=0;
function C_short(){
  if(Cs==='panel'){Ci=(Ci+1)%5;fl('C_plist',Ci);}
}
function C_long(){
  if(Cs==='panel'){
    if(Ci<4){Cs='thread';sv('scrC','C_thread');st('C_st','thread view');
      const names=['JOAQUIN','ANTHONY','BEN W.','MOM'];st('C_thread_name',names[Ci]||'THREAD');
    } else {Cs='new';sv('scrC','C_new');st('C_st','new message');}
  }
}
function C_back(){
  if(Cs!=='panel'){Cs='panel';sv('scrC','C_panel');Ci=0;fl('C_plist',0);st('C_st','messages panel');}
}

/* ════ DEVICE D: MUSIC ════ */
let Ds='panel',Di=0,Dli=0,Dqi=0,Dplaying=true;
function D_setTab(i){[0,1,2].forEach(n=>{const t=document.getElementById('D_tab'+n);if(t)t.classList.toggle('active',n===i);});}
function D_togglePlay(){Dplaying=!Dplaying;const b=document.getElementById('D_playbtn');const art=document.getElementById('D_npart');if(b)b.textContent=Dplaying?'▶':'■';if(art)art.classList.toggle('spin',Dplaying);}
function scrubClick(e,el){const r=el.getBoundingClientRect();const p=Math.round((e.clientX-r.left)/r.width*100);const f=document.getElementById('D_scrub');if(f)f.style.width=p+'%';const m=Math.floor(p*222/100),s=m%60;st('D_elapsed',Math.floor(m/60)+':'+String(s).padStart(2,'0'));}
function volClick(e,el){const r=el.getBoundingClientRect();const p=Math.round((e.clientX-r.left)/r.width*100);const f=document.getElementById('D_vol');if(f)f.style.width=p+'%';st('D_volpct',p+'%');}
function D_short(){
  if(Ds==='panel'){Di=(Di+1)%4;fl('D_plist',Di);}
  else if(Ds==='lib'){Dli=(Dli+1)%6;fl('D_llist',Dli);}
  else if(Ds==='np'){D_togglePlay();}
  else if(Ds==='queue'){Dqi=(Dqi+1)%3;fl('D_qlist',Dqi);}
}
function D_long(){
  if(Ds==='panel'){
    if(Di===0){Ds='lib';sv('scrD','D_lib');Dli=0;fl('D_llist',0);st('D_st','library');}
    else if(Di===1){Ds='np';sv('scrD','D_np');st('D_st','now playing');}
    else if(Di===2){Ds='queue';sv('scrD','D_queue');Dqi=0;fl('D_qlist',0);st('D_st','queue');}
    else{Ds='lib';sv('scrD','D_lib');st('D_st','playlists');}
  } else if(Ds==='lib'){
    const rows=document.querySelectorAll('#D_llist [data-i]');flash(rows[Dli]);
    setTimeout(()=>{Ds='np';sv('scrD','D_np');st('D_st','now playing');},200);
  } else if(Ds==='np'){D_togglePlay();}
}
function D_back(){
  if(Ds!=='panel'){Ds='panel';sv('scrD','D_panel');Di=0;fl('D_plist',0);st('D_st','music panel');}
}

/* ════ KEYBOARD (all devices) ════ */
document.addEventListener('keydown',e=>{
  if(['INPUT','TEXTAREA'].includes(document.activeElement.tagName))return;
  if(e.key===' '){e.preventDefault();A_short();B_short();C_short();D_short();}
  if(e.key==='Enter'){e.preventDefault();A_long();B_long();C_long();D_long();}
  if(e.key==='Backspace'||e.key==='Escape'){e.preventDefault();A_back();B_back();C_back();D_back();}
});
</script>

