<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<title>BITOS · FOCUS + MAIL + MSGS + MUSIC + NOTIFICATIONS</title>
<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;image-rendering:pixelated;transition:none!important;animation-timing-function:steps(1)!important}
body{background:#080808;color:#fff;font-family:'Press Start 2P',monospace;padding:40px 36px;line-height:1}
.pg-title{font-size:16px;letter-spacing:.04em;margin-bottom:6px}
.pg-sub{font-size:6px;color:#222;letter-spacing:.1em;margin-bottom:48px}
.sec-title{font-size:9px;letter-spacing:.08em;color:#333;margin-bottom:20px;padding-bottom:8px;border-bottom:1px solid #111}
.divider{border:none;border-top:2px solid #111;margin:52px 0}
.row-wrap{display:flex;flex-wrap:wrap;gap:36px;align-items:flex-start}

/* ── DEVICE SHELL ── */
.device-wrap{display:flex;flex-direction:column;align-items:center;gap:10px}
.device-lbl{font-size:5px;color:#222;letter-spacing:.1em;text-align:center;line-height:1.8}
.device{background:#0d0d0d;border:3px solid #2a2a2a;padding:8px 8px 14px;display:flex;flex-direction:column;align-items:center;gap:8px}
.screen{width:240px;height:280px;background:#000;border:2px solid #555;position:relative;overflow:hidden;font-family:‘Press Start 2P’,monospace}
.home-btn{width:32px;height:5px;background:#1a1a1a;border:1px solid #222}

/* ── SHARED PRIMITIVES ── */
.view{position:absolute;inset:0;display:none;flex-direction:column;background:#000}
.view.active{display:flex}
.sbar{height:18px;background:#fff;color:#000;display:flex;align-items:center;justify-content:space-between;padding:0 6px;font-size:6px;letter-spacing:.06em;flex-shrink:0;border-bottom:2px solid #fff}
.sbar.dark{background:#000;color:#fff;border-bottom-color:#333}
.kh{font-size:4px;color:#111;text-align:center;padding:2px 6px;letter-spacing:.06em;flex-shrink:0;border-top:1px solid #0a0a0a}
.inv-hdr{background:#fff;color:#000;padding:7px 8px;font-size:7px;letter-spacing:.06em;flex-shrink:0;border-bottom:2px solid #fff;display:flex;justify-content:space-between;align-items:center}
.scroll-body{flex:1;overflow:auto}
.scroll-body::-webkit-scrollbar{display:none}
.row{display:flex;align-items:center;gap:7px;padding:8px 8px;font-size:7px;letter-spacing:.04em;border-bottom:1px solid #0a0a0a;cursor:pointer;color:#555}
.row:last-child{border-bottom:none}
.row.focused{background:#fff;color:#000}
.row .arr{font-size:6px;flex-shrink:0;color:#333}
.row.focused .arr{color:#666}
.row .meta{margin-left:auto;font-size:5px;color:#333;flex-shrink:0}
.row.focused .meta{color:#666}
.row .rsub{font-size:5px;color:#222;margin-top:2px;letter-spacing:.04em;display:block}
.row.focused .rsub{color:#666}
.row-lbl{flex:1}
.bcur{display:inline-block;width:5px;height:9px;background:#fff;animation:bcu .8s steps(1) infinite;vertical-align:bottom}
@keyframes bcu{0%,100%{opacity:1}50%{opacity:0}}
.pbar{height:5px;border:1px solid #fff;background:#000}
.pfill{height:100%;background:#fff}
.ldbar{height:5px;border:1px solid #fff;background:#000;overflow:hidden}
.ldfill{height:100%;width:20%;background:#fff;animation:lda 1.6s steps(8) infinite}
@keyframes lda{0%{transform:translateX(-100%)}100%{transform:translateX(600%)}}
.btn-row{display:flex;gap:6px;flex-wrap:wrap;justify-content:center}
.ctrl-btn{border:2px solid #333;padding:5px 10px;font-size:5px;color:#555;cursor:pointer;letter-spacing:.06em;font-family:‘Press Start 2P’,monospace;background:#000}
.ctrl-btn:hover{border-color:#fff;color:#fff}
.state-disp{font-size:5px;color:#1a1a1a;text-align:center;letter-spacing:.06em;margin-top:4px}
.sett-section{padding:4px 8px;font-size:5px;color:#1a1a1a;letter-spacing:.12em;background:#050505;border-bottom:1px solid #080808;border-top:1px solid #080808;flex-shrink:0}

/* ── NOTIFICATION TOAST (absolute, sits above everything) ── */
.notif-toast{position:absolute;top:0;left:0;right:0;z-index:100;display:flex;flex-direction:column;transform:translateY(-100%);background:#fff;color:#000;border-bottom:2px solid #fff}
.notif-toast.visible{transform:translateY(0)}
.nt-bar{display:flex;align-items:center;gap:6px;padding:4px 7px}
.nt-icon{font-size:8px;flex-shrink:0;width:14px;text-align:center}
.nt-body{flex:1;min-width:0}
.nt-app{font-size:4px;letter-spacing:.1em;color:#666;margin-bottom:2px}
.nt-msg{font-size:6px;letter-spacing:.03em;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.nt-time{font-size:4px;color:#888;flex-shrink:0}
.nt-prog{height:2px;background:#ccc;transition:none}
.nt-prog-fill{height:100%;background:#000;width:0}

/* ── FOCUS: POMODORO ── */
.pomo-display{padding:14px 10px 10px;text-align:center;flex-shrink:0}
.pomo-time{font-size:36px;letter-spacing:.04em;line-height:1;margin-bottom:6px}
.pomo-phase{font-size:5px;color:#555;letter-spacing:.1em;margin-bottom:10px}
.pomo-prog{height:5px;border:1px solid #fff;background:#000;margin:0 10px 6px}
.pomo-dots{display:flex;justify-content:center;gap:5px;margin-bottom:0}
.pomo-dot{width:8px;height:8px;border:2px solid #333}
.pomo-dot.done{background:#fff;border-color:#fff}
.pomo-ctrl{display:flex;border-top:2px solid #fff;flex-shrink:0}
.pomo-btn{flex:1;border:none;border-right:2px solid #333;padding:9px;font-size:6px;font-family:‘Press Start 2P’,monospace;background:#000;color:#555;cursor:pointer;letter-spacing:.04em}
.pomo-btn:last-child{border-right:none}
.pomo-btn.active,.pomo-btn:hover{background:#fff;color:#000}
.break-mode .pomo-display,.break-mode .pomo-ctrl,.break-mode .pomo-dots,.break-mode .pomo-phase{filter:invert(1)}
.break-mode .sbar{background:#000;color:#fff;border-color:#333}

/* ── WORLD CLOCKS ── */
.clk-grid{display:grid;grid-template-columns:1fr 1fr;gap:0;flex:1}
.clk-cell{border-right:1px solid #111;border-bottom:1px solid #111;padding:8px 6px;display:flex;flex-direction:column;align-items:center;gap:4px}
.clk-cell:nth-child(2n){border-right:none}
.clk-cell:nth-child(3),.clk-cell:nth-child(4){border-bottom:none}
.clk-city{font-size:5px;color:#333;letter-spacing:.08em}
.clk-time{font-size:14px;letter-spacing:.04em}
.clk-ampm{font-size:5px;color:#555;letter-spacing:.06em}
.clk-date{font-size:4px;color:#222;letter-spacing:.04em}

/* ── STOPWATCH ── */
.sw-display{padding:14px 10px;text-align:center;border-bottom:2px solid #fff;flex-shrink:0}
.sw-time{font-size:24px;letter-spacing:.04em;line-height:1;margin-bottom:6px}
.sw-ms{font-size:12px;color:#555}
.sw-ctrl{display:flex;border-bottom:1px solid #333;flex-shrink:0}
.sw-btn{flex:1;border:none;border-right:2px solid #333;padding:8px;font-size:6px;font-family:‘Press Start 2P’,monospace;background:#000;color:#555;cursor:pointer}
.sw-btn:last-child{border-right:none}
.sw-btn.active,.sw-btn:hover{background:#fff;color:#000}
.sw-lap{display:flex;justify-content:space-between;padding:6px 8px;font-size:6px;color:#444;border-bottom:1px solid #0a0a0a;letter-spacing:.04em}
.sw-lap.best{color:#fff}
.sw-lap.worst{color:#f44}
.sw-lap-n{color:#333;flex-shrink:0}

/* ── MAIL ── */
.email-row{padding:8px 8px;border-bottom:1px solid #0a0a0a;cursor:pointer}
.email-row.focused{background:#fff;color:#000}
.email-row.unread .em-from{color:#fff}
.email-row.focused.unread .em-from{color:#000}
.em-r1{display:flex;justify-content:space-between;align-items:center;margin-bottom:3px}
.em-from{font-size:7px;color:#aaa;letter-spacing:.04em}
.em-time{font-size:5px;color:#333}
.em-subj{font-size:6px;color:#555;letter-spacing:.03em;margin-bottom:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.email-row.unread .em-subj{color:#aaa}
.email-row.focused .em-from,.email-row.focused .em-time,.email-row.focused .em-subj,.email-row.focused .em-prev{color:#000!important}
.em-prev{font-size:5px;color:#222;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;letter-spacing:.03em}
.email-row.unread::before{content:’’;position:absolute;left:3px;top:50%;transform:translateY(-50%);width:3px;height:3px;background:#fff}
.email-row.focused.unread::before{background:#000}
.email-row{position:relative}

/* EMAIL DETAIL */
.email-detail-hdr{padding:8px;border-bottom:2px solid #fff;flex-shrink:0}
.email-detail-from{font-size:7px;letter-spacing:.04em;margin-bottom:3px}
.email-detail-subj{font-size:6px;color:#aaa;letter-spacing:.03em;margin-bottom:2px}
.email-detail-time{font-size:5px;color:#333;letter-spacing:.04em}
.email-body{flex:1;padding:8px;font-size:6px;color:#888;line-height:2;letter-spacing:.03em;overflow:auto}
.email-body::-webkit-scrollbar{display:none}
.email-actions-bar{display:flex;border-top:2px solid #fff;flex-shrink:0}
.em-act{flex:1;border:none;border-right:2px solid #333;padding:8px;font-size:6px;font-family:‘Press Start 2P’,monospace;background:#000;color:#555;cursor:pointer}
.em-act:last-child{border-right:none}
.em-act.focused,.em-act:hover{background:#fff;color:#000}

/* COMPOSE */
.comp-field{display:flex;align-items:center;gap:7px;padding:7px 8px;border-bottom:1px solid #111;flex-shrink:0}
.comp-lbl{font-size:5px;color:#333;letter-spacing:.08em;min-width:22px;flex-shrink:0}
.comp-val{flex:1;font-size:6px;color:#aaa;letter-spacing:.04em;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.comp-val.active{color:#fff}
.comp-body{flex:1;padding:8px;font-size:6px;color:#888;line-height:2;letter-spacing:.03em;border-bottom:2px solid #333}
.comp-cur{font-size:6px;color:#fff;letter-spacing:.04em;margin-top:4px}

/* ── MESSAGES ── */
.sms-row{padding:8px 8px;border-bottom:1px solid #0a0a0a;cursor:pointer;display:flex;align-items:flex-start;gap:7px;position:relative}
.sms-row.focused{background:#fff;color:#000}
.sms-av{width:28px;height:28px;border:2px solid #333;display:flex;align-items:center;justify-content:center;font-size:7px;flex-shrink:0}
.sms-row.focused .sms-av{border-color:#000}
.sms-body{flex:1;min-width:0}
.sms-r1{display:flex;justify-content:space-between;margin-bottom:2px}
.sms-name{font-size:7px;color:#aaa;letter-spacing:.04em}
.sms-row.unread .sms-name{color:#fff}
.sms-row.focused .sms-name{color:#000!important}
.sms-t{font-size:5px;color:#333}
.sms-prev{font-size:5px;color:#222;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;letter-spacing:.03em}
.sms-row.unread .sms-prev{color:#666}
.sms-row.focused .sms-prev{color:#666!important}
.sms-dot{width:5px;height:5px;background:#fff;flex-shrink:0;margin-top:6px}
.sms-row.focused .sms-dot{background:#000}

/* SMS THREAD */
.sms-msg{display:flex;gap:4px;align-items:flex-end;padding:3px 6px}
.sms-msg.me{flex-direction:row-reverse}
.sms-bbl{border:2px solid #fff;padding:4px 5px;font-size:6px;line-height:1.6;max-width:160px}
.sms-bbl.me{background:#fff;color:#000}
.sms-inp-bar{height:28px;border-top:2px solid #fff;display:flex;flex-shrink:0}
.sms-inp{flex:1;background:transparent;border:none;color:#fff;font-family:‘Press Start 2P’,monospace;font-size:5px;padding:4px 6px;outline:none}
.sms-inp::placeholder{color:#1a1a1a}
.sms-send{width:28px;border-left:2px solid #fff;background:#000;color:#fff;font-size:10px;display:flex;align-items:center;justify-content:center;cursor:pointer}
.sms-send:hover{background:#fff;color:#000}

/* ── MUSIC ── */
.ml-tabs{display:flex;border-bottom:2px solid #fff;flex-shrink:0}
.ml-tab{flex:1;padding:7px 4px;font-size:5px;color:#444;letter-spacing:.06em;text-align:center;cursor:pointer;border-right:1px solid #333}
.ml-tab:last-child{border-right:none}
.ml-tab.active{background:#fff;color:#000}
.ml-row{display:flex;align-items:center;gap:7px;padding:8px 8px;font-size:6px;letter-spacing:.04em;border-bottom:1px solid #0a0a0a;cursor:pointer;color:#555}
.ml-row.focused{background:#fff;color:#000}
.ml-row.playing{color:#fff}
.ml-art{width:26px;height:26px;border:2px solid #333;display:flex;align-items:center;justify-content:center;font-size:10px;flex-shrink:0}
.ml-row.focused .ml-art{border-color:#000}
.ml-info{flex:1;min-width:0}
.ml-track{margin-bottom:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.ml-artist{font-size:5px;color:#333;letter-spacing:.04em}
.ml-row.focused .ml-artist{color:#666}
.ml-dur{font-size:5px;color:#333;flex-shrink:0}
.ml-row.focused .ml-dur{color:#666}
.now-bar{border-top:2px solid #fff;padding:7px 8px;display:flex;align-items:center;gap:7px;flex-shrink:0}
.np-art{width:36px;height:36px;border:2px solid #fff;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0}
.np-art.spin{animation:spin 2s steps(8) infinite}
@keyframes spin{0%{transform:rotate(0)}100%{transform:rotate(360deg)}}
.np-info{flex:1;min-width:0}
.np-track{font-size:6px;letter-spacing:.04em;margin-bottom:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.np-artist{font-size:5px;color:#444;letter-spacing:.04em}
.np-ctrls{display:flex;gap:3px}
.np-btn{border:2px solid #fff;width:20px;height:20px;display:flex;align-items:center;justify-content:center;font-size:7px;cursor:pointer;color:#888}
.np-btn:hover,.np-btn.playing{color:#fff}
.np-btn.playing:hover{background:#fff;color:#000}

/* FULL NOW PLAYING */
.full-np-art{width:100px;height:100px;border:3px solid #fff;display:flex;align-items:center;justify-content:center;font-size:40px;margin:0 auto}
.full-np-art.spin{animation:spin 2s steps(8) infinite}
.scrub{height:5px;border:1px solid #fff;background:#000;margin:0 10px 4px;cursor:pointer}
.scrub-fill{height:100%;background:#fff}
.scrub-times{display:flex;justify-content:space-between;padding:0 10px;font-size:5px;color:#444;letter-spacing:.04em;margin-bottom:8px}
.full-ctrls{display:flex;justify-content:center;gap:8px;padding:0 10px}
.full-btn{border:2px solid #fff;width:32px;height:32px;display:flex;align-items:center;justify-content:center;font-size:12px;cursor:pointer;color:#888}
.full-btn.play{width:40px;height:40px;font-size:16px;color:#fff}
.full-btn:hover,.full-btn.play:hover{background:#fff;color:#000}

/* ── NOTIFICATION DESIGN KIT ── */
.notif-kit{max-width:900px}
.nk-row{display:flex;flex-wrap:wrap;gap:20px;margin-bottom:24px}
.nk-item{border:2px solid #fff;overflow:hidden;width:280px}
.nk-hdr{background:#fff;color:#000;padding:5px 10px;font-size:6px;letter-spacing:.06em;border-bottom:2px solid #fff;display:flex;justify-content:space-between}
.nk-toast{background:#fff;color:#000;display:flex;align-items:center;gap:7px;padding:6px 8px;border-bottom:1px solid #ccc}
.nk-toast-icon{font-size:9px;flex-shrink:0;width:14px;text-align:center}
.nk-toast-body{flex:1;min-width:0}
.nk-toast-app{font-size:4px;letter-spacing:.1em;color:#666;margin-bottom:2px}
.nk-toast-msg{font-size:7px;letter-spacing:.03em;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.nk-toast-time{font-size:4px;color:#999;flex-shrink:0}
.nk-prog{height:2px;background:#ddd}
.nk-prog-fill{height:100%;background:#000}
.nk-note{padding:6px 8px;font-size:5px;color:#444;letter-spacing:.06em;line-height:1.8;border-top:1px solid #eee}
.notif-shade{border:2px solid #fff;width:280px;overflow:hidden}
.ns-hdr{background:#fff;color:#000;padding:6px 8px;font-size:7px;letter-spacing:.06em;border-bottom:2px solid #fff;display:flex;justify-content:space-between;align-items:center}
.ns-clear{font-size:5px;color:#555;border:1px solid #555;padding:1px 5px;cursor:pointer}
.ns-row{padding:8px 8px;border-bottom:1px solid #0a0a0a;cursor:pointer;position:relative}
.ns-row.new{border-left:3px solid #fff}
.ns-row:hover{background:#080808}
.ns-app{font-size:4px;color:#333;letter-spacing:.1em;margin-bottom:3px;display:flex;align-items:center;gap:4px}
.ns-app-dot{width:4px;height:4px;border-radius:50%;background:#555}
.ns-app-dot.mail{background:#D85A30}
.ns-app-dot.sms{background:#1D9E75}
.ns-app-dot.task{background:#BA7517}
.ns-app-dot.claude{background:#7F77DD}
.ns-msg{font-size:6px;color:#888;letter-spacing:.03em;line-height:1.7}
.ns-row.new .ns-msg{color:#aaa}
.ns-time{font-size:4px;color:#222;letter-spacing:.04em;margin-top:3px}
</style>

</head>
<body>

<div class="pg-title">BITOS · FOCUS + MAIL + MSGS + MUSIC + NOTIFICATIONS</div>
<div class="pg-sub">4 FLOW SIMULATORS · FULL NOTIFICATION DESIGN KIT · 240×280PX</div>

<!-- ════════════════════════════
     SIMULATORS
════════════════════════════ -->

<div class="sec-title">01 · LIVE SIMULATORS · SPACE=SHORT · ENTER=LONG · BACKSPACE=BACK</div>

<div class="row-wrap">

<!-- ══════ DEVICE A · FOCUS ══════ -->

<div class="device-wrap" id="DA">
  <div class="device-lbl">FOCUS · POMODORO + CLOCKS + STOPWATCH</div>
  <div class="device">
    <div class="screen" id="scrA">

```
  <!-- FOCUS PANEL -->
  <div class="view active" id="A_panel">
    <div class="sbar dark"><span>← DBL</span><span>FOCUS</span><span id="At">--:--</span></div>
    <div class="inv-hdr">LAST SESSION <span style="font-size:5px;color:#555">WORK · 1/4</span></div>
    <div style="padding:10px 8px;border-bottom:2px solid #fff;text-align:center;flex-shrink:0">
      <div style="font-size:24px;letter-spacing:.04em;margin-bottom:4px">25:00</div>
      <div style="font-size:5px;color:#333;letter-spacing:.1em">READY TO START</div>
    </div>
    <div class="scroll-body" id="A_plist">
      <div class="row focused" data-i="0"><span class="arr">▶</span><span class="row-lbl">START POMODORO</span></div>
      <div class="row" data-i="1"><span class="arr">▶</span><span class="row-lbl">WORLD CLOCKS</span></div>
      <div class="row" data-i="2"><span class="arr">▶</span><span class="row-lbl">STOPWATCH</span></div>
    </div>
    <div class="kh">SHORT:NEXT · LONG:OPEN · DBL:BACK</div>
  </div>

  <!-- POMODORO -->
  <div class="view" id="A_pomo">
    <div class="sbar dark" id="A_pomobar"><span>← DBL</span><span>FOCUS</span><span id="A_pomosess">1/4</span></div>
    <div id="A_pomodisp" class="pomo-display">
      <div style="font-size:5px;color:#555;letter-spacing:.1em;margin-bottom:4px" id="A_pomophase">WORK SESSION</div>
      <div class="pomo-time" id="A_pomotime">25:00</div>
      <div class="pomo-prog"><div class="pfill" id="A_pomoprog" style="width:0%"></div></div>
      <div style="display:flex;justify-content:space-between;font-size:4px;color:#1a1a1a;margin-bottom:8px"><span>0%</span><span id="A_pomoeta">DONE: --:--</span></div>
      <div class="pomo-dots" id="A_pomo_dots">
        <div class="pomo-dot done"></div><div class="pomo-dot"></div><div class="pomo-dot"></div><div class="pomo-dot"></div>
      </div>
    </div>
    <div class="pomo-ctrl">
      <div class="pomo-btn" id="A_pomobtn" onclick="A_pomoToggle()">START</div>
      <div class="pomo-btn" onclick="A_pomoSkip()">SKIP ▶</div>
      <div class="pomo-btn" onclick="A_pomoReset()">RESET</div>
    </div>
    <div class="kh">SHORT:START/STOP · LONG:SKIP · DBL:BACK</div>
  </div>

  <!-- WORLD CLOCKS -->
  <div class="view" id="A_clocks">
    <div class="sbar"><span>← DBL</span><span>WORLD CLOCKS</span><span></span></div>
    <div class="clk-grid">
      <div class="clk-cell">
        <div class="clk-city">LOS ANGELES</div>
        <canvas id="clkLA" width="52" height="52"></canvas>
        <div class="clk-time" id="clkLAt">--:--</div>
        <div class="clk-ampm" id="clkLAap">--</div>
        <div class="clk-date" id="clkLAd">---</div>
      </div>
      <div class="clk-cell">
        <div class="clk-city">NEW YORK</div>
        <canvas id="clkNY" width="52" height="52"></canvas>
        <div class="clk-time" id="clkNYt">--:--</div>
        <div class="clk-ampm" id="clkNYap">--</div>
        <div class="clk-date" id="clkNYd">---</div>
      </div>
      <div class="clk-cell">
        <div class="clk-city">LONDON</div>
        <canvas id="clkLN" width="52" height="52"></canvas>
