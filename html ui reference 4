<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<title>BITOS · REMAINING SCREENS</title>
<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;image-rendering:pixelated;transition:none!important;animation-timing-function:steps(1)!important}
body{background:#080808;color:#fff;font-family:'Press Start 2P',monospace;padding:40px 36px;line-height:1}
.pg-title{font-size:16px;letter-spacing:.04em;margin-bottom:6px}
.pg-sub{font-size:6px;color:#222;letter-spacing:.1em;margin-bottom:48px}
.sec-title{font-size:9px;letter-spacing:.08em;color:#333;margin-bottom:20px;padding-bottom:8px;border-bottom:1px solid #111}
.divider{border:none;border-top:2px solid #111;margin:52px 0}
.row-wrap{display:flex;flex-wrap:wrap;gap:36px;align-items:flex-start}
.device-wrap{display:flex;flex-direction:column;align-items:center;gap:10px}
.device-lbl{font-size:5px;color:#222;letter-spacing:.1em;text-align:center;line-height:1.8}
.device{background:#0d0d0d;border:3px solid #2a2a2a;padding:8px 8px 14px;display:flex;flex-direction:column;align-items:center;gap:8px}
.screen{width:240px;height:280px;background:#000;border:2px solid #555;position:relative;overflow:hidden;font-family:'Press Start 2P',monospace}
.home-btn{width:32px;height:5px;background:#1a1a1a;border:1px solid #222}
.view{position:absolute;inset:0;display:none;flex-direction:column;background:#000}
.view.active{display:flex}
.sbar{height:18px;background:#fff;color:#000;display:flex;align-items:center;justify-content:space-between;padding:0 6px;font-size:6px;letter-spacing:.06em;flex-shrink:0;border-bottom:2px solid #fff}
.sbar.dark{background:#000;color:#fff;border-bottom-color:#333}
.kh{font-size:4px;color:#111;text-align:center;padding:2px 6px;letter-spacing:.06em;flex-shrink:0;border-top:1px solid #0a0a0a}
.scroll-body{flex:1;overflow:auto}
.scroll-body::-webkit-scrollbar{display:none}
.row{display:flex;align-items:center;gap:7px;padding:8px 8px;font-size:7px;letter-spacing:.04em;border-bottom:1px solid #0a0a0a;cursor:pointer;color:#555}
.row.focused{background:#fff;color:#000}
.row .arr{font-size:6px;flex-shrink:0;color:#333}
.row.focused .arr{color:#666}
.row .meta{margin-left:auto;font-size:5px;color:#333;flex-shrink:0}
.row.focused .meta{color:#666}
.bcur{display:inline-block;width:5px;height:9px;background:#fff;animation:bcu .8s steps(1) infinite;vertical-align:bottom}
@keyframes bcu{0%,100%{opacity:1}50%{opacity:0}}
.btn-row{display:flex;gap:6px;flex-wrap:wrap;justify-content:center}
.ctrl-btn{border:2px solid #333;padding:5px 10px;font-size:5px;color:#555;cursor:pointer;letter-spacing:.06em;font-family:'Press Start 2P',monospace;background:#000}
.ctrl-btn:hover{border-color:#fff;color:#fff}
.state-disp{font-size:5px;color:#1a1a1a;text-align:center;letter-spacing:.06em;margin-top:4px}
.inv-hdr{background:#fff;color:#000;padding:7px 8px;font-size:7px;letter-spacing:.06em;flex-shrink:0;border-bottom:2px solid #fff;display:flex;justify-content:space-between;align-items:center}
.pbar{height:4px;border:1px solid #fff;background:#000}
.pfill{height:100%;background:#fff}

/* ── LOCK SCREEN ── */
.lock-digits{display:flex;justify-content:center;gap:10px;padding:20px 0 12px}
.lock-digit{width:40px;height:50px;border:3px solid #333;display:flex;align-items:center;justify-content:center;font-size:22px;letter-spacing:.04em}
.lock-digit.filled{border-color:#fff}
.lock-digit.active{border-color:#fff;background:#fff;color:#000;animation:digblink .6s steps(1) infinite}
@keyframes digblink{0%,100%{background:#fff;color:#000}50%{background:#000;color:#fff}}
.lock-digit.error{border-color:#f44;animation:errshake .2s steps(2) 2}
@keyframes errshake{0%,100%{transform:translateX(0)}50%{transform:translateX(4px)}}
.num-grid{display:grid;grid-template-columns:repeat(11,1fr);gap:3px;padding:8px 6px;border-top:2px solid #111;flex-shrink:0}
.num-key{border:2px solid #333;padding:6px 2px;font-size:7px;text-align:center;cursor:pointer;letter-spacing:.04em;color:#555}
.num-key.focused{background:#fff;color:#000;border-color:#fff}
.num-key.del{font-size:5px;border-color:#444;color:#444}
.num-key.del.focused{background:#f44;color:#000;border-color:#f44}

/* ── ONBOARDING ── */
.ob-step{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;padding:16px 12px;text-align:center}
.ob-icon{font-size:32px;line-height:1;margin-bottom:4px}
.ob-title{font-size:9px;letter-spacing:.04em;line-height:1.6}
.ob-sub{font-size:6px;color:#444;letter-spacing:.04em;line-height:1.8;max-width:200px}
.ob-progress{display:flex;justify-content:center;gap:5px;padding:6px 0;flex-shrink:0}
.ob-dot{width:8px;height:8px;border:2px solid #333}
.ob-dot.done{background:#fff;border-color:#fff}
.ob-dot.active{border-color:#fff}
.ob-action{border-top:2px solid #fff;flex-shrink:0}
.ob-btn{padding:10px 8px;font-size:7px;letter-spacing:.04em;text-align:center;cursor:pointer;color:#555}
.ob-btn.focused{background:#fff;color:#000}
.wifi-item{display:flex;align-items:center;gap:7px;padding:8px 8px;font-size:6px;border-bottom:1px solid #0a0a0a;cursor:pointer;color:#555;letter-spacing:.04em}
.wifi-item.focused{background:#fff;color:#000}
.wifi-bars{display:flex;align-items:flex-end;gap:1px;height:10px;flex-shrink:0}
.wifi-bar{width:3px;background:#333}
.wifi-bar.on{background:#fff}
.wifi-item.focused .wifi-bar.on{background:#000}
.key-entry{display:grid;grid-template-columns:repeat(5,1fr);gap:2px;padding:6px;flex-shrink:0}
.key-btn{border:1px solid #1a1a1a;padding:5px 2px;font-size:6px;text-align:center;cursor:pointer;color:#333;letter-spacing:.04em}
.key-btn.focused{background:#fff;color:#000;border-color:#fff}
.key-display{padding:6px 8px;font-size:7px;color:#aaa;letter-spacing:.06em;border-bottom:1px solid #0a0a0a;min-height:24px;flex-shrink:0}

/* ── GLOBAL SEARCH ── */
.search-bar{display:flex;align-items:center;gap:6px;padding:8px 8px;border-bottom:3px solid #fff;flex-shrink:0}
.search-icon{font-size:10px;color:#555;flex-shrink:0}
.search-inp{flex:1;background:transparent;border:none;color:#fff;font-family:‘Press Start 2P’,monospace;font-size:7px;outline:none;letter-spacing:.04em}
.search-inp::placeholder{color:#1a1a1a}
.search-section{padding:4px 8px;font-size:4px;color:#1a1a1a;letter-spacing:.12em;background:#050505;border-bottom:1px solid #080808}
.search-result{display:flex;align-items:center;gap:7px;padding:7px 8px;font-size:6px;letter-spacing:.04em;border-bottom:1px solid #0a0a0a;cursor:pointer;color:#555}
.search-result.focused{background:#fff;color:#000}
.search-result .sr-type{font-size:4px;border:1px solid #333;padding:1px 3px;color:#333;letter-spacing:.06em;flex-shrink:0}
.search-result.focused .sr-type{border-color:#666;color:#666}
.search-result .sr-match{color:#fff;font-size:6px}
.search-result.focused .sr-match{color:#000}

/* ── QUICK CAPTURE ── */
.qc-overlay{position:absolute;inset:0;background:rgba(0,0,0,.92);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;padding:16px;z-index:50}
.qc-ring{width:80px;height:80px;border:3px solid #fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:28px;position:relative}
.qc-ring.rec{animation:qcrec .5s steps(2) infinite}
@keyframes qcrec{0%,100%{border-color:#fff}50%{border-color:#f44}}
.qc-ring.rec::after{content:’’;position:absolute;inset:-7px;border:2px solid #f44;border-radius:50%;animation:qcring .5s steps(1) infinite}
@keyframes qcring{0%,100%{opacity:1}50%{opacity:0}}
.qc-bars{display:flex;align-items:center;gap:2px;height:20px}
.qcb{width:3px;background:#fff}
.qcb:nth-child(1){animation:vba .5s steps(4) infinite 0s}
.qcb:nth-child(2){animation:vba .5s steps(4) infinite .07s}
.qcb:nth-child(3){animation:vba .5s steps(4) infinite .14s}
.qcb:nth-child(4){animation:vba .5s steps(4) infinite .04s}
.qcb:nth-child(5){animation:vba .5s steps(4) infinite .11s}
.qcb:nth-child(6){animation:vba .5s steps(4) infinite .18s}
.qcb:nth-child(7){animation:vba .5s steps(4) infinite .06s}
@keyframes vba{0%{height:2px}25%{height:8px}50%{height:16px}75%{height:5px}}
.qc-intent{width:100%;border:2px solid #fff;overflow:hidden;margin-top:4px}
.qc-intent-hdr{background:#fff;color:#000;padding:5px 8px;font-size:6px;letter-spacing:.06em;border-bottom:2px solid #fff}
.qc-choice{padding:7px 8px;font-size:7px;letter-spacing:.04em;border-bottom:1px solid #0a0a0a;display:flex;align-items:center;gap:6px;cursor:pointer;color:#555}
.qc-choice:last-child{border-bottom:none}
.qc-choice.focused{background:#fff;color:#000}

/* ── SLEEP / WAKE ── */
.sleep-screen{background:#000;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px}
.sleep-time{font-size:36px;letter-spacing:.04em;color:#111;text-align:center}
.sleep-date{font-size:6px;color:#0a0a0a;letter-spacing:.06em}
.sleep-dot{width:4px;height:4px;background:#111;border-radius:50%;animation:sdot 3s steps(1) infinite}
@keyframes sdot{0%,60%,100%{opacity:1}30%{opacity:0}}

/* ── ERROR STATES ── */
.error-screen{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;padding:12px;text-align:center}
.err-icon{font-size:28px;line-height:1}
.err-title{font-size:9px;letter-spacing:.04em}
.err-sub{font-size:6px;color:#555;letter-spacing:.04em;line-height:1.8}
.err-retry{border:2px solid #fff;padding:8px 14px;font-size:7px;cursor:pointer;margin-top:4px;letter-spacing:.04em}
.err-retry:hover{background:#fff;color:#000}
.batt-critical{background:#1a0000}
.batt-crit-bar{height:8px;border:2px solid #f44;background:#000;margin:0 12px}
.batt-crit-fill{height:100%;width:8%;background:#f44;animation:battcrit 1s steps(1) infinite}
@keyframes battcrit{0%,100%{opacity:1}50%{opacity:.3}}

/* ── CONTACTS ── */
.contact-alpha{padding:4px 8px;font-size:4px;color:#1a1a1a;letter-spacing:.12em;background:#050505;border-bottom:1px solid #080808}
.contact-row{display:flex;align-items:center;gap:7px;padding:7px 8px;border-bottom:1px solid #0a0a0a;cursor:pointer}
.contact-row.focused{background:#fff;color:#000}
.contact-av{width:24px;height:24px;border:2px solid #333;display:flex;align-items:center;justify-content:center;font-size:7px;flex-shrink:0;letter-spacing:0}
.contact-row.focused .contact-av{border-color:#000}
.contact-name{font-size:7px;color:#aaa;letter-spacing:.04em}
.contact-row.focused .contact-name{color:#000}
.contact-role{font-size:5px;color:#333;letter-spacing:.04em;margin-top:2px}
.contact-row.focused .contact-role{color:#666}
</style>

</head>
