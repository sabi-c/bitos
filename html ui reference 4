  <div style="font-size:6px;color:#2a2a2a;letter-spacing:.1em;margin-bottom:14px">SLEEP / WAKE SPEC</div>
  <div style="display:flex;flex-direction:column;gap:10px;font-size:5px;letter-spacing:.06em">
    <div style="border-left:2px solid #fff;padding-left:8px">
      <div style="color:#fff;margin-bottom:3px">AWAKE</div>
      <div style="color:#1a1a1a;line-height:2">Normal operation. Screen at full brightness. Button responsive.</div>
    </div>
    <div style="border-left:2px solid #555;padding-left:8px">
      <div style="color:#555;margin-bottom:3px">DIM · 50s idle</div>
      <div style="color:#1a1a1a;line-height:2">Screen dims to 30%. Any press → back to awake (no action executed).</div>
    </div>
    <div style="border-left:2px solid #333;padding-left:8px">
      <div style="color:#333;margin-bottom:3px">SLEEP · 60s idle</div>
      <div style="color:#1a1a1a;line-height:2">Display off. Subtle clock in #111. PiSugar in low-power mode. Any press → 1-frame white flash → awake.</div>
    </div>
    <div style="border-left:2px solid #f44;padding-left:8px">
      <div style="color:#f44;margin-bottom:3px">BATTERY CRITICAL · &lt;10%</div>
      <div style="color:#1a1a1a;line-height:2">Red pulsing bar. Mail + Music disabled. AI chat stays active. Forces sleep at 5%.</div>
    </div>
    <div style="border-left:2px solid #0f0;padding-left:8px">
      <div style="color:#0f0;margin-bottom:3px">CHARGING</div>
      <div style="color:#1a1a1a;line-height:2">Green battery indicator. Sleep timeout extends to 5 min. No low-power restrictions.</div>
    </div>
    <div style="border-top:1px solid #111;padding-top:8px;color:#111;line-height:2">Timeout configurable in Settings → Display → Sleep Timer (30s / 60s / 2min / Never)</div>
  </div>
</div>

<!-- QUICK CAPTURE SPEC CARD -->

<div style="border:2px solid #1a1a1a;padding:16px;max-width:320px;align-self:flex-start">
  <div style="font-size:6px;color:#2a2a2a;letter-spacing:.1em;margin-bottom:14px">QUICK CAPTURE SPEC</div>
  <div style="display:flex;flex-direction:column;gap:10px;font-size:5px;letter-spacing:.06em">
    <div style="border-left:2px solid #fff;padding-left:8px">
      <div style="color:#fff;margin-bottom:3px">TRIGGER · TRIPLE PRESS</div>
      <div style="color:#1a1a1a;line-height:2">3 taps within 600ms from any screen. Overlay appears immediately. Previous screen stays underneath.</div>
    </div>
    <div style="border-left:2px solid #555;padding-left:8px">
      <div style="color:#555;margin-bottom:3px">RECORD · HOLD</div>
      <div style="color:#1a1a1a;line-height:2">Hold = record. Waveform bars animate. Timer counts up. Max 60s. Release = stop + transcribe.</div>
    </div>
    <div style="border-left:2px solid #555;padding-left:8px">
      <div style="color:#555;margin-bottom:3px">AI INTENT DETECTION</div>
      <div style="color:#1a1a1a;line-height:2">Haiku 4.5 classifies: TASK (action + deadline), NOTE (information), CHAT (question/idea). Shows top choice + alternatives.</div>
    </div>
    <div style="border-left:2px solid #555;padding-left:8px">
      <div style="color:#555;margin-bottom:3px">CONFIRM · SHORT/LONG</div>
      <div style="color:#1a1a1a;line-height:2">Short = next option. Long = confirm selected. Double = dismiss without saving.</div>
    </div>
    <div style="border-left:2px solid #0f0;padding-left:8px">
      <div style="color:#0f0;margin-bottom:3px">SAVE + RETURN</div>
      <div style="color:#1a1a1a;line-height:2">Saves to Things/Obsidian/Claude. Overlay dismisses. Returns to screen that was showing before.</div>
    </div>
  </div>
</div>

</div><!-- /row-wrap 3 -->

<script>
/* ════ UTILS ════ */
function sv(scrId,viewId){document.querySelectorAll('#'+scrId+' .view').forEach(v=>v.classList.remove('active'));document.getElementById(viewId)?.classList.add('active');}
function fl(listId,idx){const rows=document.querySelectorAll('#'+listId+' [data-i]');rows.forEach((r,i)=>r.classList.toggle('focused',i===idx));if(rows[idx])rows[idx].scrollIntoView({block:'nearest'});return rows.length;}
function flash(el,ms=120){if(!el)return;const prevBg=el.style.background,prevC=el.style.color;el.style.background='#fff';el.style.color='#000';setTimeout(()=>{el.style.background=prevBg;el.style.color=prevC;},ms);}
function st(id,txt){const e=document.getElementById(id);if(e)e.textContent=txt;}

/* clock */
function tick(){const n=new Date();const t=String(n.getHours()).padStart(2,'0')+':'+String(n.getMinutes()).padStart(2,'0');['A_lt','E_at'].forEach(id=>{const e=document.getElementById(id);if(e)e.textContent=t;});const e=document.getElementById('E_sltime');if(e)e.textContent=t;const de=document.getElementById('E_sldate');if(de){const days=['SUN','MON','TUE','WED','THU','FRI','SAT'],mons=['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];de.textContent=days[n.getDay()]+' '+n.getDate()+' '+mons[n.getMonth()];}}
tick();setInterval(tick,1000);

/* ════ DEVICE A: LOCK ════ */
let A_numIdx=0,A_digits=['','','',''],A_digitPos=0;
const PIN='1234';
const A_KEYS=['1','2','3','4','5','6','7','8','9','0','del'];
function A_renderDigits(){
  ['A_d0','A_d1','A_d2','A_d3'].forEach((id,i)=>{
    const el=document.getElementById(id);
    if(!el)return;
    el.className='lock-digit';
    if(i<A_digitPos)el.classList.add('filled');
    if(i===A_digitPos)el.classList.add('active');
    el.textContent=A_digits[i]||'_';
  });
}
function A_short(){A_numIdx=(A_numIdx+1)%11;fl('A_numgrid',A_numIdx);st('A_st','lock · key '+A_numIdx+' · digit '+A_digitPos);}
function A_long(){
  const key=A_KEYS[A_numIdx];
  if(key==='del'){A_back();return;}
  if(A_digitPos<4){
    A_digits[A_digitPos]=key;
    A_digitPos++;
    A_renderDigits();
    if(A_digitPos===4){
      const entered=A_digits.join('');
      if(entered===PIN){
        sv('scrA','A_unlocked');st('A_st','UNLOCKED');
        setTimeout(()=>{sv('scrA','A_lock');A_resetLock();},1000);
      } else {
        // error
        ['A_d0','A_d1','A_d2','A_d3'].forEach(id=>{const e=document.getElementById(id);if(e)e.classList.add('error');});
        const le=document.getElementById('A_lerr');if(le)le.textContent='INCORRECT PIN';
        setTimeout(()=>{A_resetLock();},800);
      }
    }
    st('A_st','lock · key '+A_numIdx+' · digit '+A_digitPos);
  }
}
function A_back(){
  if(A_digitPos>0){A_digitPos--;A_digits[A_digitPos]='';A_renderDigits();const le=document.getElementById('A_lerr');if(le)le.textContent='\u00a0';st('A_st','lock · key '+A_numIdx+' · digit '+A_digitPos);}
}
function A_resetLock(){A_numIdx=0;A_digits=['','','',''];A_digitPos=0;fl('A_numgrid',0);A_renderDigits();const le=document.getElementById('A_lerr');if(le)le.textContent='\u00a0';st('A_st','lock · key 0 · digit 0');}
A_renderDigits();

/* ════ DEVICE B: ONBOARDING ════ */
let Bs='ob1',Bwi=0,Bai=0;
function B_goTo(s){Bs=s;sv('scrB','B_'+s);st('B_st',s);}
function B_short(){
  if(Bs==='ob2'){Bwi=(Bwi+1)%4;fl('B_wlist',Bwi);}
  else if(Bs==='ob4'){Bai=(Bai+1)%5;fl('B_alist',Bai);}
}
function B_long(){
  if(Bs==='ob1')B_goTo('ob2');
  else if(Bs==='ob2')B_goTo('ob3');
  else if(Bs==='ob3')B_goTo('ob4');
  else if(Bs==='ob4'){const rows=document.querySelectorAll('#B_alist [data-i]');flash(rows[Bai]);setTimeout(()=>B_goTo('ob5'),200);}
  else if(Bs==='ob5'){st('B_st','COMPLETE → launching home');}
}
function B_back(){
  const steps={ob2:'ob1',ob3:'ob2',ob4:'ob3',ob5:'ob4'};
  if(steps[Bs])B_goTo(steps[Bs]);
}
/* draw QR placeholder */
(function(){const c=document.getElementById('qr_placeholder');if(!c)return;c.width=80;c.height=80;const ctx=c.getContext('2d');ctx.fillStyle='#fff';ctx.fillRect(0,0,80,80);ctx.fillStyle='#000';for(let r=0;r<20;r++)for(let col=0;col<20;col++){if(Math.random()>0.5)ctx.fillRect(col*4,r*4,4,4);}ctx.fillStyle='#fff';ctx.fillRect(2,2,22,22);ctx.fillRect(56,2,22,22);ctx.fillRect(2,56,22,22);ctx.fillStyle='#000';ctx.fillRect(4,4,18,18);ctx.fillStyle='#fff';ctx.fillRect(6,6,14,14);ctx.fillStyle='#000';ctx.fillRect(8,8,10,10);ctx.fillRect(58,4,18,18);ctx.fillStyle='#fff';ctx.fillRect(60,6,14,14);ctx.fillStyle='#000';ctx.fillRect(62,8,10,10);ctx.fillRect(4,58,18,18);ctx.fillStyle='#fff';ctx.fillRect(6,60,14,14);ctx.fillStyle='#000';ctx.fillRect(8,62,10,10);})();

/* ════ DEVICE C: SEARCH ════ */
let Ci=0,Cstate='results';
function C_short(){if(Cstate==='results'){Ci=(Ci+1)%7;fl('C_results',Ci);st('C_st','results · idx '+Ci);}}
function C_long(){if(Cstate==='results'){const rows=document.querySelectorAll('#C_results [data-i]');flash(rows[Ci]);setTimeout(()=>st('C_st','opened result '+Ci),200);}}
function C_back(){st('C_st','dismissed');}
function C_toggle(){Cstate=Cstate==='results'?'empty':'results';sv('scrC',Cstate==='results'?'C_search':'C_empty');st('C_st',Cstate);}

/* ════ DEVICE D: QUICK CAPTURE ════ */
let D_recSec=0,D_recInt=null,D_intentIdx=0;
function D_showCapture(){
  document.getElementById('D_qcov').style.display='flex';
  document.getElementById('D_qcintent').style.display='none';
  st('D_qcstate','HOLD TO RECORD');
  st('D_st','capture overlay · idle');
}
function D_startRec(){
  const ring=document.getElementById('D_qcring');const state=document.getElementById('D_qcstate');
  if(ring)ring.classList.add('rec');
  if(state)state.textContent='RECORDING...';
  D_recSec=0;
  D_recInt=setInterval(()=>{D_recSec++;const el=document.getElementById('D_qctimer');if(el)el.textContent='00:'+String(D_recSec).padStart(2,'0');},1000);
  st('D_st','recording');
}
function D_stopRec(){
  clearInterval(D_recInt);
  const ring=document.getElementById('D_qcring');if(ring)ring.classList.remove('rec');
  const el=document.getElementById('D_qctimer');if(el)el.textContent='00:00';
  st('D_st','stopped · transcribing...');
  setTimeout(D_showIntent,600);
}
function D_showIntent(){
  document.getElementById('D_qcov').style.display='none';
  document.getElementById('D_qcintent').style.display='flex';
  D_intentIdx=0;fl('D_qcintent',-1);
  document.querySelectorAll('.qc-choice').forEach((r,i)=>r.classList.toggle('focused',i===0));
  st('D_st','intent picker · task');
}
function D_shortIntent(){
  D_intentIdx=(D_intentIdx+1)%3;
  document.querySelectorAll('.qc-choice').forEach((r,i)=>r.classList.toggle('focused',i===D_intentIdx));
  const names=['task','note','send to claude'];st('D_st','intent: '+names[D_intentIdx]);
}
function D_longIntent(){
  const rows=document.querySelectorAll('.qc-choice');flash(rows[D_intentIdx]);
  setTimeout(D_resetCapture,300);
  st('D_st','saved! returning...');
}
function D_resetCapture(){
  document.getElementById('D_qcov').style.display='none';
  document.getElementById('D_qcintent').style.display='none';
  clearInterval(D_recInt);D_recSec=0;
  const el=document.getElementById('D_qctimer');if(el)el.textContent='00:00';
  const ring=document.getElementById('D_qcring');if(ring)ring.classList.remove('rec');
  st('D_st','dismissed · back to previous');
}

/* ════ DEVICE E: SLEEP/WAKE ════ */
function E_go(state){sv('scrE','E_'+state);st('E_st',state);}
function E_wake(){sv('scrE','E_wake');setTimeout(()=>{sv('scrE','E_awake');st('E_st','awake (woke from sleep)');},80);}

/* ════ DEVICE F: ERRORS ════ */
let F_ti=0;
function fRetry(){const b=document.getElementById('F_t0');if(b){b.textContent='RETRYING...';setTimeout(()=>b.textContent='RETRY ↻',1200);}}

/* ════ DEVICE G: CONTACTS ════ */
let Gi=0,Gs='list',Gai=0;
function G_short(){
  if(Gs==='list'){Gi=(Gi+1)%5;fl('G_clist',Gi);st('G_st','contact list · idx '+Gi);}
  else if(Gs==='detail'){Gai=(Gai+1)%4;fl('G_acts',Gai);st('G_st','contact detail · action '+Gai);}
}
function G_long(){
  if(Gs==='list'){Gs='detail';sv('scrG','G_detail');Gai=0;fl('G_acts',0);st('G_st','contact detail · action 0');}
  else if(Gs==='detail'){const rows=document.querySelectorAll('#G_acts [data-i]');flash(rows[Gai]);setTimeout(()=>st('G_st','action: '+(Gai===0?'email':Gai===1?'message':Gai===2?'claude':'note')),200);}
}
function G_back(){if(Gs==='detail'){Gs='list';sv('scrG','G_list');Gi=0;fl('G_clist',0);st('G_st','contact list · idx 0');}}

/* ════ KEYBOARD ════ */
document.addEventListener('keydown',e=>{
  if(['INPUT','TEXTAREA'].includes(document.activeElement.tagName))return;
  if(e.key===' '){e.preventDefault();A_short();B_short();C_short();}
  if(e.key==='Enter'){e.preventDefault();A_long();B_long();C_long();}
  if(e.key==='Backspace'||e.key==='Escape'){e.preventDefault();A_back();B_back();C_back();G_back();}
});
</script>

</body>
</html>