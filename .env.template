# Required
ANTHROPIC_API_KEY=sk-ant-...

# Server
SERVER_URL=http://localhost:8000
LLM_PROVIDER=anthropic
MODEL_NAME=claude-sonnet-4-6

# Device hardware (pi: st7789/hw:0/gpio, desktop: pygame/mock/keyboard)
BITOS_DISPLAY=pygame
BITOS_AUDIO=mock
BITOS_BUTTON=keyboard
BITOS_WIFI=mock
BITOS_BLUETOOTH=mock
BITOS_BATTERY=mock
BITOS_ADAPTER_MODE=echo

# Security (generated by 02b_secrets.sh on Pi)
BITOS_DEVICE_TOKEN=
BITOS_PIN_HASH=
BITOS_BLE_SECRET=

# Companion PWA
BITOS_COMPANION_URL=https://bitos-p8xw.onrender.com

# Sleep/display
SCREEN_SLEEP_TIMEOUT=60
SCREEN_DIM_AT=50

# Optional
BITOS_DB_FILE=device/data/bitos.db
UI_SETTINGS_FILE=server/data/ui_settings.json

# Compatibility aliases used by existing runtime/config
BITOS_SERVER_URL=http://localhost:8000
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
BITOS_SYSTEM_PROMPT=You are BITOS, a helpful pocket AI companion. Keep responses concise.

# OpenAI-compatible providers (OpenAI/OpenClaw/NanoClaw)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

OPENCLAW_API_KEY=
OPENCLAW_BASE_URL=https://api.openclaw.example/v1
OPENCLAW_MODEL=openclaw-default

NANOCLAW_API_KEY=
NANOCLAW_BASE_URL=https://api.nanoclaw.example/v1
NANOCLAW_MODEL=nanoclaw-default

# Wake-word (optional)
BITOS_WAKE_WORD=off   # set to 'on' after pip install openwakeword
