# Required
ANTHROPIC_API_KEY=sk-ant-...

# Server
SERVER_URL=http://localhost:8000
LLM_PROVIDER=anthropic
MODEL_NAME=claude-sonnet-4-6

# Device hardware (pi: st7789/hw:0/gpio, desktop: pygame/mock/keyboard)
WHISPLAY_DRIVER_PATH=/home/pi/Whisplay/Driver
BITOS_DISPLAY=pygame
BITOS_AUDIO=mock
ALSA_RECORD_DEVICE=hw:0,0
ALSA_PLAYBACK_DEVICE=hw:0,0
AUDIO_CHANNELS=2
ALSA_SAMPLE_RATE=48000
AUDIO_SAMPLE_RATE=48000
BITOS_BUTTON=keyboard
BITOS_WIFI=mock
BITOS_BLUETOOTH=mock
BITOS_BATTERY=mock
BITOS_ADAPTER_MODE=echo

# Security (generated by 02b_secrets.sh on Pi)
BITOS_DEVICE_TOKEN=
BITOS_PIN_HASH=
BITOS_BLE_SECRET=
BITOS_BLE_ADDRESS=AA:BB:CC:DD:EE:FF

# Companion PWA
BITOS_COMPANION_URL=https://bitos-p8xw.onrender.com

# Sleep/display
SCREEN_SLEEP_TIMEOUT=60
SCREEN_DIM_AT=50
WHISPLAY_BACKLIGHT_LEVEL=100

# Optional
BITOS_DB_FILE=device/data/bitos.db
UI_SETTINGS_FILE=server/data/ui_settings.json

# Compatibility aliases used by existing runtime/config
BITOS_SERVER_URL=http://localhost:8000
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
BITOS_SYSTEM_PROMPT=You are BITOS, a helpful pocket AI companion. Keep responses concise.

# Voice transcription (cloud STT — set at least one for voice to work)
GROQ_API_KEY=              # Tier 1: Distil-Whisper, $0.02/hr, fastest
# OPENAI_API_KEY also used for Tier 2: Whisper API, $0.006/min

# Speechify TTS (optional — Tier 0 voice, overrides Piper/OpenAI/eSpeak)
SPEECHIFY_API_KEY=
SPEECHIFY_VOICE_ID=sophia  # Voice: george, henry, carly, sophia
SPEECHIFY_MODEL=simba-english

# OpenAI-compatible providers (OpenAI/OpenClaw/NanoClaw)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

OPENCLAW_API_KEY=
OPENCLAW_BASE_URL=https://api.openclaw.example/v1
OPENCLAW_MODEL=openclaw-default

NANOCLAW_API_KEY=
NANOCLAW_BASE_URL=https://api.nanoclaw.example/v1
NANOCLAW_MODEL=nanoclaw-default

# Vikunja task provider (optional)
VIKUNJA_BASE_URL=https://tasks.example.com/api/v1
VIKUNJA_API_TOKEN=

# Wake-word (optional)
BITOS_WAKE_WORD=off   # set to 'on' after pip install openwakeword
PIPER_MODEL=/home/pi/bitos/models/tts/en_US-lessac-medium.onnx


# BlueBubbles iMessage provider (optional)
BLUEBUBBLES_BASE_URL=http://localhost:1234
BLUEBUBBLES_PASSWORD=
# leave empty for mock mode

# Gmail MCP provider (optional)
GMAIL_ENABLED=false
# Set to true on Mac mini where Gmail MCP is authenticated
# Requires Anthropic API key with Gmail MCP access

WHISPLAY_DRIVER_PATH=/home/pi/Whisplay/Driver
