#cloud-config
hostname: bitos
manage_etc_hosts: true

users:
  - name: pi
    shell: /bin/bash
    sudo: ALL=(ALL) NOPASSWD:ALL
    groups: [adm, dialout, cdrom, audio, video, plugdev, users, netdev, spi, i2c, gpio]
    ssh_authorized_keys:
      - YOUR_SSH_PUBLIC_KEY_HERE

write_files:
  - path: /etc/bitos/repo_url
    permissions: '0644'
    owner: root:root
    content: |
      https://github.com/YOUR_GITHUB_USERNAME/bitos.git

runcmd:
  - mkdir -p /etc/bitos
  - chown -R pi:pi /home/pi
