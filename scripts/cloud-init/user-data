#cloud-config
hostname: bitos
manage_etc_hosts: true

users:
  - name: pi
    shell: /bin/bash
    sudo: ALL=(ALL) NOPASSWD:ALL
    groups: [adm, dialout, cdrom, audio, video, plugdev, users, netdev, spi, i2c, gpio]
    ssh_authorized_keys:
      - ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIOoNVUv0P0BGNuh4sL1zmHtK2bv/b4COlW2IzRHeG4XW seb@bitos

runcmd:
  - sleep 30
  - git clone https://github.com/sabi-c/bitos.git /home/pi/bitos
  - chown -R pi:pi /home/pi/bitos
  - sudo -u pi bash /home/pi/bitos/scripts/install.sh --non-interactive
