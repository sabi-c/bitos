# ── BITOS Device Environment ──────────────────────────────
# Copy this to .env and fill in your keys:
#   cp .env.example .env && nano .env

# ── LLM Chat (required for chat) ─────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
# MODEL_NAME=claude-sonnet-4-6  # default

# ── Voice / Transcription (required for voice input) ─────
OPENAI_API_KEY=sk-your-key-here

# ── Audio Hardware ────────────────────────────────────────
# Pi with WM8960: hw:0
# Desktop/dev: mock (default)
BITOS_AUDIO=mock
# ALSA_RECORD_DEVICE=hw:0,0
# ALSA_PLAYBACK_DEVICE=hw:0,0

# ── Display ───────────────────────────────────────────────
# Pi with ST7789: st7789
# Desktop/dev: pygame (default)
# BITOS_DISPLAY=st7789

# ── Button ────────────────────────────────────────────────
# Pi with GPIO: gpio
# Desktop/dev: keyboard (default)
# BITOS_BUTTON=gpio

# ── TTS (optional — falls back to espeak if not set) ─────
# PIPER_MODEL=/home/pi/bitos/models/tts/en_US-lessac-medium.onnx

# ── Speechify TTS (optional — best voice quality) ────────
# SPEECHIFY_API_KEY=your-speechify-api-key
# SPEECHIFY_VOICE_ID=sophia        # george, henry, carly, sophia
# SPEECHIFY_MODEL=simba-english

# ── UI Scale ──────────────────────────────────────────────
# Global font scale multiplier (1.0 = default, 1.5 = 50% bigger)
# BITOS_FONT_SCALE=1.0

# ── BLE (optional) ───────────────────────────────────────
# BITOS_BLE=mock  # set to 'mock' to disable BLE
# BITOS_PIN_HASH=
# BITOS_BLE_SECRET=

# ── Server (if running backend on different machine) ─────
# BITOS_SERVER_URL=http://localhost:8000
