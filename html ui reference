/* ════ BOOT ORBS ════ */
let bootFrame = 0;
function drawBoot() {
  const c = document.getElementById('bootCanvas');
  if (!c) return;
  c.width = 120; c.height = 120;
  const ctx = c.getContext('2d');
  ctx.imageSmoothingEnabled = false;
  ctx.clearRect(0, 0, 120, 120);

  const cx = 60, cy = 60, r = 36;
  const t = bootFrame * 0.04;
  const orbSize = 14;

  for (let i = 0; i < 4; i++) {
    const angle = t + i * Math.PI / 2;
    const ox = Math.round(cx + r * Math.cos(angle));
    const oy = Math.round(cy + r * Math.sin(angle));

    // Pixel-draw orb (square pixelated circle)
    ctx.fillStyle = '#fff';
    const pixSize = 2;
    for (let py = -4; py <= 4; py++) {
      for (let px = -4; px <= 4; px++) {
        if (px*px + py*py <= 16) {
          ctx.fillRect(ox + px*pixSize, oy + py*pixSize, pixSize, pixSize);
        }
      }
    }

    // Dim trail
    const trailAngle = t + i * Math.PI / 2 - 0.3;
    const tx2 = Math.round(cx + r * Math.cos(trailAngle));
    const ty2 = Math.round(cy + r * Math.sin(trailAngle));
    ctx.fillStyle = '#333';
    for (let py = -3; py <= 3; py++) {
      for (let px2 = -3; px2 <= 3; px2++) {
        if (px2*px2 + py*py <= 9) {
          ctx.fillRect(tx2 + px2*pixSize, ty2 + py*pixSize, pixSize, pixSize);
        }
      }
    }
  }

  // Pixel center dot
  ctx.fillStyle = '#222';
  ctx.fillRect(56, 56, 8, 8);
  ctx.fillStyle = '#fff';
  ctx.fillRect(58, 58, 4, 4);

  bootFrame++;
  requestAnimationFrame(drawBoot);
}
drawBoot();

