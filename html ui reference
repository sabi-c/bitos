<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<title>BITOS · NAV ARCHITECTURE + SIMULATOR</title>
<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;image-rendering:pixelated}
body{background:#0a0a0a;color:#fff;font-family:'Press Start 2P',monospace;padding:40px 36px;line-height:1}
.pg-title{font-size:16px;letter-spacing:.04em;margin-bottom:6px}
.pg-sub{font-size:6px;color:#2a2a2a;letter-spacing:.1em;margin-bottom:48px}
.section-title{font-size:11px;letter-spacing:.06em;color:#444;margin-bottom:24px}
.divider{border:none;border-top:2px solid #111;margin:56px 0}

/* ── ARCHITECTURE DIAGRAM ── */
.arch{display:flex;flex-direction:column;gap:0;max-width:960px}
.arch-row{display:flex;align-items:stretch;gap:0;border-bottom:1px solid #111}
.arch-row:last-child{border-bottom:none}
.arch-layer-lbl{width:80px;flex-shrink:0;display:flex;align-items:center;justify-content:flex-end;padding:0 12px 0 0;font-size:5px;color:#1a1a1a;letter-spacing:.1em;border-right:1px solid #111}
.arch-cells{flex:1;display:flex;gap:0;padding:12px;flex-wrap:wrap}
.arch-cell{border:2px solid #333;padding:10px 14px;font-size:7px;letter-spacing:.04em;cursor:default;position:relative;margin:3px}
.arch-cell.purple{border-color:#7F77DD;color:#7F77DD}
.arch-cell.teal{border-color:#1D9E75;color:#1D9E75}
.arch-cell.amber{border-color:#BA7517;color:#BA7517}
.arch-cell.white{border-color:#fff;color:#fff}
.arch-cell.dim{border-color:#1a1a1a;color:#222}
.arch-cell-sub{font-size:5px;color:#333;margin-top:4px;letter-spacing:.06em}
.arch-cell.purple .arch-cell-sub{color:#534AB7}
.arch-cell.teal .arch-cell-sub{color:#0F6E56}
.arch-cell.white .arch-cell-sub{color:#666}
.arch-arrow-row{display:flex;align-items:center;padding:4px 12px 4px 92px;font-size:5px;color:#1a1a1a;letter-spacing:.06em;gap:8px}

/* ── INPUT MODEL ── */
.input-model{display:flex;gap:0;border:2px solid #fff;max-width:720px;margin-top:24px}
.input-col{flex:1;padding:12px;border-right:2px solid #333}
.input-col:last-child{border-right:none}
.input-gesture{font-size:8px;letter-spacing:.04em;margin-bottom:6px}
.input-timing{font-size:5px;color:#333;letter-spacing:.08em;margin-bottom:6px}
.input-action{font-size:6px;color:#aaa;letter-spacing:.04em}

/* ── DEVICE SIMULATOR ── */
.sim-wrap{display:flex;gap:48px;align-items:flex-start;flex-wrap:wrap}
.device-outer{display:flex;flex-direction:column;align-items:center;gap:8px}
.device-lbl{font-size:5px;color:#2a2a2a;letter-spacing:.1em}
.device{background:#0d0d0d;border:3px solid #2a2a2a;padding:8px 8px 14px;display:flex;flex-direction:column;align-items:center;gap:8px}
/* Actual 240x280 screen, scaled 2x for readability */
.screen{width:240px;height:280px;background:#000;border:2px solid #555;position:relative;overflow:hidden;font-family:‘Press Start 2P’,monospace}
.home-btn{width:32px;height:5px;background:#1a1a1a;border:1px solid #222;margin-top:6px}

/* VIEWS */
.view{position:absolute;inset:0;display:none;flex-direction:column;background:#000}
.view.active{display:flex}

/* STATUS BAR */
.sbar{height:18px;background:#fff;color:#000;display:flex;align-items:center;justify-content:space-between;padding:0 6px;font-size:6px;letter-spacing:.06em;flex-shrink:0;border-bottom:2px solid #fff}
.sbar.inv{background:#000;color:#fff;border-color:#333}

/* KEY HINT */
.kh{font-size:4px;color:#111;text-align:center;padding:2px 6px;letter-spacing:.06em;flex-shrink:0;border-top:1px solid #0a0a0a}

/* ── BOOT SCREEN ── */
#bootView{align-items:center;justify-content:center;gap:0}
.boot-canvas-wrap{display:flex;flex-direction:column;align-items:center;gap:10px;padding:20px}

/* ── NAV SHELL ── */
.nav-shell{flex:1;display:flex;overflow:hidden}
.sidebar{width:84px;flex-shrink:0;border-right:2px solid #fff;display:flex;flex-direction:column;overflow-y:auto;overflow-x:hidden}
.sidebar::-webkit-scrollbar{width:0}
.sb-item{padding:9px 7px;font-size:7px;letter-spacing:.04em;color:#444;cursor:pointer;border-bottom:1px solid #0a0a0a;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;flex-shrink:0}
.sb-item.selected{background:#fff;color:#000}
.sb-item:hover:not(.selected){background:#080808;color:#aaa}

/* RIGHT PANEL */
.rpanel{flex:1;display:flex;flex-direction:column;overflow:hidden}
.rp-hdr{background:#fff;color:#000;padding:5px 8px;font-size:7px;letter-spacing:.06em;border-bottom:2px solid #fff;flex-shrink:0;display:flex;justify-content:space-between;align-items:center}
.rp-body{flex:1;overflow:auto}
.rp-body::-webkit-scrollbar{width:0}

/* RIGHT PANEL: HOME */
.home-panel .rp-time{font-size:22px;letter-spacing:.04em;text-align:center;padding:12px 8px 4px}
.home-panel .rp-date{font-size:6px;color:#555;text-align:center;letter-spacing:.06em;margin-bottom:10px}
.home-panel .rp-weather{display:flex;align-items:center;justify-content:center;gap:6px;padding:8px;border:2px solid #1a1a1a;margin:0 8px 10px}
.home-panel .rp-weather-temp{font-size:14px}
.home-panel .rp-weather-info{font-size:5px;color:#444;letter-spacing:.06em;line-height:1.8}
.home-panel .rp-task-hdr{font-size:5px;color:#333;letter-spacing:.1em;padding:0 8px 4px;border-bottom:1px solid #0a0a0a;margin-bottom:0}
.home-panel .rp-task{padding:7px 8px;font-size:6px;color:#aaa;letter-spacing:.04em;border-bottom:1px solid #0a0a0a;display:flex;align-items:center;gap:6px}
.home-panel .rp-task.focused{background:#fff;color:#000}
.home-panel .rp-task-dot{width:5px;height:5px;background:#555;flex-shrink:0}
.home-panel .rp-task.focused .rp-task-dot{background:#000}
.home-panel .rp-task.urgent .rp-task-dot{background:#f44}

/* RIGHT PANEL: CHAT */
.chat-panel .ai-stat-row{display:flex;align-items:center;justify-content:space-between;padding:6px 8px;font-size:6px;letter-spacing:.04em;border-bottom:1px solid #0a0a0a;color:#aaa}
.chat-panel .ai-stat-val{color:#fff}
.chat-panel .ai-stat-val.ok{color:#0f0}
.chat-panel .ai-stat-val.warn{color:#ff0}
.chat-panel .ai-dot{width:6px;height:6px;background:#0f0;display:inline-block;margin-right:4px;animation:asdot 1s steps(1) infinite}
@keyframes asdot{0%,100%{background:#0f0}50%{background:#0a2a0a}}
.chat-panel .ctx-ring-row{padding:8px;display:flex;align-items:center;gap:8px;border-bottom:1px solid #0a0a0a}
.chat-panel .ctx-bar{flex:1;height:5px;border:1px solid #fff;background:#000}
.chat-panel .ctx-fill{height:100%;width:84%;background:#fff}
.chat-panel .chat-action{padding:9px 8px;font-size:7px;letter-spacing:.04em;border-bottom:1px solid #0a0a0a;color:#555;cursor:pointer;display:flex;align-items:center;gap:6px}
.chat-panel .chat-action.focused{background:#fff;color:#000}
.chat-panel .chat-action .ca-arr{font-size:6px}

/* RIGHT PANEL: TASKS */
.tasks-panel .task-preview{padding:7px 8px;font-size:6px;color:#aaa;letter-spacing:.04em;border-bottom:1px solid #0a0a0a;display:flex;align-items:center;gap:5px}
.tasks-panel .task-preview .tp-dot{width:4px;height:4px;background:#555;flex-shrink:0}
.tasks-panel .task-preview .tp-dot.hi{background:#f44}
.tasks-panel .task-action{padding:9px 8px;font-size:7px;letter-spacing:.04em;border-bottom:1px solid #0a0a0a;color:#555;cursor:pointer;display:flex;align-items:center;gap:6px}
.tasks-panel .task-action.focused{background:#fff;color:#000}

/* RIGHT PANEL: SETTINGS */
.settings-panel .sett-row{padding:9px 8px;font-size:7px;letter-spacing:.04em;border-bottom:1px solid #0a0a0a;color:#555;cursor:pointer;display:flex;align-items:center;justify-content:space-between}
.settings-panel .sett-row.focused{background:#fff;color:#000}
.settings-panel .sett-val{font-size:6px;color:#333}
.settings-panel .sett-row.focused .sett-val{color:#666}

/* RIGHT PANEL: FOCUS */
.focus-panel .focus-action{padding:9px 8px;font-size:7px;letter-spacing:.04em;border-bottom:1px solid #0a0a0a;color:#555;cursor:pointer;display:flex;align-items:center;gap:6px}
.focus-panel .focus-action.focused{background:#fff;color:#000}

/* RIGHT PANEL: MAIL */
.mail-panel .mail-row{padding:8px;border-bottom:1px solid #0a0a0a;cursor:pointer}
.mail-panel .mail-row.focused{background:#fff;color:#000}
.mail-panel .mail-from{font-size:7px;color:#aaa;letter-spacing:.04em;margin-bottom:3px;display:flex;justify-content:space-between}
.mail-panel .mail-row.focused .mail-from{color:#000}
.mail-panel .mail-subj{font-size:6px;color:#555;letter-spacing:.03em;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.mail-panel .mail-row.unread .mail-from{color:#fff}
.mail-panel .mail-row.focused.unread .mail-from{color:#000}
.mail-panel .mail-row.unread .mail-subj{color:#aaa}

/* RIGHT PANEL: MESSAGES */
.msgs-panel .msg-row{padding:8px;border-bottom:1px solid #0a0a0a;cursor:pointer;display:flex;gap:6px}
.msgs-panel .msg-row.focused{background:#fff;color:#000}
.msgs-panel .msg-av{width:24px;height:24px;border:2px solid #333;font-size:7px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.msgs-panel .msg-row.focused .msg-av{border-color:#000}
.msgs-panel .msg-name{font-size:7px;color:#aaa;letter-spacing:.04em;margin-bottom:3px}
.msgs-panel .msg-row.focused .msg-name{color:#000}
.msgs-panel .msg-preview{font-size:5px;color:#333;letter-spacing:.03em;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.msgs-panel .msg-row.unread .msg-name{color:#fff}

/* RIGHT PANEL: MUSIC */
.music-panel .now-playing{padding:10px 8px;border-bottom:2px solid #fff;display:flex;flex-direction:column;align-items:center;gap:4px}
.music-panel .np-art{width:44px;height:44px;border:2px solid #fff;display:flex;align-items:center;justify-content:center;font-size:18px;animation:spin 2s steps(8) infinite}
@keyframes spin{0%{transform:rotate(0)}100%{transform:rotate(360deg)}}
.music-panel .np-track{font-size:7px;letter-spacing:.04em;text-align:center;margin-top:4px}
.music-panel .np-artist{font-size:5px;color:#444;letter-spacing:.04em}
.music-panel .music-row{padding:7px 8px;font-size:6px;color:#444;letter-spacing:.04em;border-bottom:1px solid #0a0a0a;cursor:pointer;display:flex;align-items:center;gap:5px;white-space:nowrap;overflow:hidden}
.music-panel .music-row.focused{background:#fff;color:#000}
.music-panel .music-row.playing{color:#fff}
.music-panel .music-row.playing::before{content:’♪ ’;color:#fff}
.music-panel .music-row.focused.playing::before{color:#000}

/* RIGHT PANEL: HISTORY */
.history-panel .hist-row{padding:7px 8px;border-bottom:1px solid #0a0a0a;cursor:pointer}
.history-panel .hist-row.focused{background:#fff;color:#000}
.history-panel .hist-title{font-size:7px;color:#aaa;letter-spacing:.04em;margin-bottom:2px}
.history-panel .hist-row.focused .hist-title{color:#000}
.history-panel .hist-meta{font-size:5px;color:#333;letter-spacing:.04em}
.history-panel .hist-row.focused .hist-meta{color:#666}

/* BLOCK CURSOR */
.bcur{display:inline-block;width:6px;height:10px;background:#fff;animation:bcu .8s steps(1) infinite;vertical-align:bottom}
@keyframes bcu{0%,100%{opacity:1}50%{opacity:0}}

/* LOADING DOTS */
@keyframes tda{0%,100%{background:#222}50%{background:#fff}}

/* LEGEND TABLE */
.legend{border:2px solid #fff;max-width:700px;margin-top:32px}
.legend-hdr{background:#fff;color:#000;padding:7px 12px;font-size:7px;letter-spacing:.06em;display:flex;justify-content:space-between;align-items:center;border-bottom:2px solid #fff}
.legend-row{display:flex;align-items:center;padding:7px 12px;border-bottom:1px solid #0a0a0a;font-size:6px;letter-spacing:.04em;gap:0}
.legend-row:last-child{border-bottom:none}
.legend-item{flex:1;display:flex;align-items:center;gap:8px}
.legend-key{border:2px solid #fff;padding:2px 6px;font-size:5px;white-space:nowrap;letter-spacing:.06em}
.legend-arrow{color:#333;padding:0 8px}
.legend-action{color:#aaa}
</style>

</head>
