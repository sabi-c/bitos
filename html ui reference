/* ════ RENDER PANEL ════ */
function renderPanel(name) {
  const rp = document.getElementById('rpanel');
  rp.innerHTML = PANELS[name]?.() || `<div class="rp-hdr">${name.toUpperCase()}</div><div style="padding:12px 8px;font-size:6px;color:#222">COMING SOON</div>`;
  // Update home clock
  if (name === 'home') updateHomePanel();
}

function updateHomePanel() {
  const n = new Date();
  const h = n.getHours()%12||12, m = String(n.getMinutes()).padStart(2,'0');
  const days = ['SUN','MON','TUE','WED','THU','FRI','SAT'];
  const mons = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
  const el = document.getElementById('rp-clock');
  const del = document.getElementById('rp-date');
  if (el) el.textContent = h+':'+m;
  if (del) del.textContent = days[n.getDay()]+' '+mons[n.getMonth()]+' '+n.getDate();
}

/* ════ NAV LOGIC ════ */
function goNav() {
  document.getElementById('v-boot').classList.remove('active');
  document.getElementById('v-nav').classList.add('active');
  state = 'sidebar';
  sidebarIdx = 0;
  updateSidebar();
  renderPanel(SIDEBAR_ITEMS[0]);
}

function updateSidebar() {
  document.querySelectorAll('.sb-item').forEach((el, i) => {
    el.classList.toggle('selected', i === sidebarIdx);
  });
  // scroll sidebar to show selected
  const items = document.querySelectorAll('.sb-item');
  if (items[sidebarIdx]) items[sidebarIdx].scrollIntoView({block:'nearest'});
}

function updatePanelFocus(idx) {
  const rp = document.getElementById('rpanel');
  const focusable = rp.querySelectorAll('[class*="action"],[class*="sett-row"],[class*="mail-row"],[class*="msg-row"],[class*="music-row"],[class*="hist-row"],[class*="chat-action"],[class*="task-action"],[class*="focus-action"],[class*="rp-task"]');
  focusable.forEach((el, i) => el.classList.toggle('focused', i === idx));
  if (focusable[idx]) focusable[idx].scrollIntoView({block:'nearest'});
}

function getPanelItems() {
  const rp = document.getElementById('rpanel');
  return [...rp.querySelectorAll('[class*="action"],[class*="sett-row"],[class*="mail-row"],[class*="msg-row"],[class*="music-row"],[class*="hist-row"],[class*="chat-action"],[class*="task-action"],[class*="focus-action"],[class*="rp-task"]')];
}

function handleShort() {
  if (state === 'boot') return;
  if (state === 'sidebar') {
    sidebarIdx = (sidebarIdx + 1) % SIDEBAR_ITEMS.length;
    updateSidebar();
    renderPanel(SIDEBAR_ITEMS[sidebarIdx]);
    panelIdx = 0;
  } else if (state === 'panel') {
    const items = getPanelItems();
    if (!items.length) return;
    panelIdx = (panelIdx + 1) % items.length;
    updatePanelFocus(panelIdx);
  }
}

function handleLong() {
  if (state === 'boot') {
    goNav();
    return;
  }
  if (state === 'sidebar') {
    // Enter panel mode — focus moves to right panel
    state = 'panel';
    panelIdx = 0;
    updatePanelFocus(0);
    // visual: dim sidebar slightly
    document.querySelectorAll('.sb-item').forEach(el => {
      if (el.classList.contains('selected')) el.style.background = '#111';
    });
  } else if (state === 'panel') {
    // Would open sub-screen — for now flash selection
    const items = getPanelItems();
    if (items[panelIdx]) {
      const el = items[panelIdx];
      const prev = el.style.background;
      el.style.background = '#fff';
      el.style.color = '#000';
      setTimeout(() => { el.style.background = ''; el.style.color = ''; updatePanelFocus(panelIdx); }, 150);
    }
  }
}

function handleDouble() {
  if (state === 'boot') return;
  if (state === 'panel') {
    state = 'sidebar';
    // unfocus panel items
    getPanelItems().forEach(el => el.classList.remove('focused'));
    // restore sidebar selection
    document.querySelectorAll('.sb-item').forEach(el => el.style.background = '');
    updateSidebar();
    panelIdx = 0;
  } else if (state === 'sidebar') {
    // already at top level — maybe show status or do nothing
  }
}

function reboot() {
  state = 'boot';
  document.getElementById('v-nav').classList.remove('active');
  document.getElementById('v-boot').classList.add('active');
  sidebarIdx = 0;
  panelIdx = 0;
}

/* ════ KEYBOARD ════ */
document.addEventListener('keydown', e => {
  if (document.activeElement.tagName === 'INPUT' || document.activeElement.tagName === 'TEXTAREA') return;
  if (e.key === ' ') { e.preventDefault(); handleShort(); }
  if (e.key === 'Enter') { e.preventDefault(); handleLong(); }
  if (e.key === 'Backspace' || e.key === 'Escape') { e.preventDefault(); handleDouble(); }
});

/* ════ SIDEBAR CLICK ════ */
document.querySelectorAll('.sb-item').forEach((el, i) => {
  el.addEventListener('click', () => {
    sidebarIdx = i;
    state = 'sidebar';
    updateSidebar();
    renderPanel(SIDEBAR_ITEMS[i]);
    panelIdx = 0;
  });
});

/* ════ INIT ════ */
renderPanel('home');
setInterval(() => { if (document.getElementById('rp-clock')) updateHomePanel(); }, 1000);
